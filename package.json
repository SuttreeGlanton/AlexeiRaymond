{
  "name": "alexei-raymond-author-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run clean && npm run verify:data && astro build && npm run fix:sitemap",
    "preview": "astro preview",
    "verify:data": "node scripts/verify-site-data.mjs",
    "audit:privacy": "node scripts/audit-privacy.mjs",
    "audit:privacy:deep": "node scripts/audit-privacy.mjs --deep",
    "check:links": "node scripts/check-links.mjs",
    "check:links:strict": "node scripts/check-links.mjs --strict-external",
    "check:links:local": "node scripts/check-links.mjs --skip-external",
    "check:assets": "node scripts/check-assets.mjs",
    "check:metadata": "node scripts/check-metadata.mjs",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "fix:sitemap": "node scripts/fix-sitemap.mjs",
    "check": "astro check"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/eb-garamond": "^5.2.7",
    "@fontsource/sorts-mill-goudy": "^5.2.8",
    "@google/model-viewer": "4.3.1",
    "astro": "^7.1.0",
    "meshoptimizer": "0.24.0"
  },
  "devDependencies": {
    "sharp": "^0.35.3",
    "@astrojs/check": "^0.9.4",
    "typescript": "^5.8.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
