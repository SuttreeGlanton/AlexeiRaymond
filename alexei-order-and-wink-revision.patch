-/* --- 193 Lines of Sight: a single, literal wink in the prose --- */
+/* --- 193 Lines of Sight: a recurring wink with a hover/focus response --- */
 .tal-wink {
-  position: relative;
-  display: inline-block;
-  transform-origin: 50% 62%;
+  display: inline;
+  outline: 1px dotted transparent;
+  outline-offset: 2px;
+  animation: talWordWink 6.4s ease-in-out infinite;
 }
 
-.tal-wink::after {
-  content: '';
-  position: absolute;
-  top: -0.08em;
-  right: -0.18em;
-  width: 0.13em;
-  height: 0.13em;
-  border-radius: 50%;
-  background: currentColor;
-  box-shadow: 0 0 0.34em currentColor;
-  opacity: 0;
-  pointer-events: none;
+@keyframes talWordWink {
+  0%, 71%, 75%, 100% { opacity: 1; }
+  73% { opacity: 0.14; }
 }
 
-.tal-wink.is-winking {
-  animation: talWordWink 820ms cubic-bezier(0.22, 1, 0.36, 1) both;
+.tal-wink:hover,
+.tal-wink:focus-visible {
+  animation: talWordWinkNow 520ms ease-in-out both;
 }
 
-.tal-wink.is-winking::after {
-  animation: talWordGlint 820ms ease-out both;
+.tal-wink:focus-visible {
+  outline-color: var(--border-strong);
 }
 
-@keyframes talWordWink {
-  0%, 22%, 100% { transform: scaleY(1); filter: brightness(1); }
