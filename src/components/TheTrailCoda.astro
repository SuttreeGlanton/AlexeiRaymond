      position: sticky;
      top: 96px;
      align-self: start;
      justify-self: end;
      width: 100%;
    }

    .archived-piece-page--trail .trail-cover-slot .archive-cover-card {
      position: static;
      top: auto;
      width: 100%;
      margin: 0;
    }
  }
</style>

<style>
  .trail-coda {
    margin: 0;
    text-indent: 0;
  }

  /* ---------- desktop trail ---------- */
  .trail-coda--desktop {
    display: grid;
    justify-items: center;
    row-gap: 7px;
    margin-top: 22px;
  }

  .tt-strip {
    display: grid;
    justify-items: center;
    row-gap: 7px;
  }

  .tt-pill {
    display: block;
    width: 46px;
    margin: 0;
    border: 0;
    padding: 0;
    background: transparent;
    opacity: 0;
    transform: translateY(-10px) rotate(var(--tt-tilt, 0deg));
    transition: opacity 420ms ease, transform 420ms cubic-bezier(0.3, 1.3, 0.5, 1);
    pointer-events: none;
  }

  .tt-pill svg {
    display: block;
    width: 100%;
    height: auto;
  }

  /* every other dose lands the other way round */
  .tt-pill[data-index='1'] svg,
  .tt-pill[data-index='3'] svg,
  .tt-pill[data-index='5'] svg,
  .tt-pill[data-index='7'] svg {
    transform: scaleX(-1);
  }

  .tt-pill.is-laid {
    opacity: 1;
    transform: translateY(0) rotate(var(--tt-tilt, 0deg));
  }

  .tt-pill[data-index='0'] { --tt-tilt: -7deg; margin-left: -16px; }
  .tt-pill[data-index='1'] { --tt-tilt: 5deg; margin-left: 12px; }
  .tt-pill[data-index='2'] { --tt-tilt: -3deg; margin-left: -6px; }
  .tt-pill[data-index='3'] { --tt-tilt: 8deg; margin-left: 18px; }
  .tt-pill[data-index='4'] { --tt-tilt: -6deg; margin-left: -12px; }
  .tt-pill[data-index='5'] { --tt-tilt: 3deg; margin-left: 8px; }
  .tt-pill[data-index='6'] { --tt-tilt: -4deg; margin-left: -9px; }
  .tt-pill[data-index='7'] { --tt-tilt: 0deg; }

  .tt-pill--last.is-laid {
    cursor: pointer;
    pointer-events: auto;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    animation: ttLastGlow 3.4s ease-in-out infinite;
  }

  .tt-pill--last.is-laid:hover {
    animation-play-state: paused;
    filter: brightness(1.5) drop-shadow(0 0 7px rgba(216, 213, 204, 0.5));
  }

  .tt-pill--last:focus-visible {
    outline: 1px solid var(--dim, #5e5a54);
    outline-offset: 5px;
  }

  @keyframes ttLastGlow {
    0%, 100% { filter: brightness(1) drop-shadow(0 0 0 rgba(216, 213, 204, 0)); }
    50% { filter: brightness(1.45) drop-shadow(0 0 6px rgba(216, 213, 204, 0.4)); }
  }

  /* ---------- mobile blister pack ---------- */
  .trail-coda--mobile {
    display: grid;
    justify-items: center;
    margin: clamp(4rem, 10vw, 7rem) 0 0;
  }

  .tt-pack {
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 6px 8px;
    justify-items: center;
    border: 1px solid var(--border, #272727);
    border-radius: 10px;
    padding: 14px 16px;
    background: linear-gradient(160deg, #191919 0%, #141414 60%, #101010 100%);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.05), 0 12px 30px rgba(0, 0, 0, 0.35);
  }

  .tt-blister {
    display: block;
    width: 52px;
    margin: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
    touch-action: manipulation;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
  }

  .tt-blister svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .tt-blister:focus-visible {
    outline: 1px solid var(--dim, #5e5a54);
    outline-offset: 3px;
  }

  .tt-blister .tt-blister-popped { opacity: 0; }
  .tt-blister.is-popped .tt-blister-full { opacity: 0; }
  .tt-blister.is-popped .tt-blister-popped { opacity: 1; }
  .tt-blister.is-popped { cursor: default; }

  .tt-blister.is-popping {
    animation: ttPop 160ms ease-out;
  }

  @keyframes ttPop {
    0% { transform: scale(1); }
    45% { transform: scale(0.88); }
    100% { transform: scale(1); }
  }

  /* ---------- breakpoints ---------- */
  @media (max-width: 860px) {
    .trail-coda--desktop { display: none; }
  }

  @media (min-width: 861px) {
    .trail-coda--mobile { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .tt-pill {
      transition: none;
      transform: rotate(var(--tt-tilt, 0deg));
    }

    .tt-pill--last.is-laid,
    .tt-blister.is-popping {
      animation: none;
    }
  }
</style>
