<script>
  const trailInstances = Array.from(document.querySelectorAll<HTMLElement>('[data-trail-coda]'));

  if (trailInstances.length > 0) {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    /* ---------- desktop: doses laid down along the reading ---------- */
    const desktopTrail = trailInstances.find((el) => el.dataset.variant === 'desktop');
    const prose = document.querySelector('.archive-prose');

    if (desktopTrail && prose instanceof HTMLElement) {
      const LAID_KEY = 'trail-pills-laid';
      const thresholds = [0.05, 0.18, 0.31, 0.44, 0.57, 0.7, 0.83, 0.94];
      const pills = Array.from(desktopTrail.querySelectorAll<HTMLElement>('[data-tt-pill]'));
      let laid = Number(window.sessionStorage.getItem(LAID_KEY) || 0) || 0;

      const applyLaid = () => {
        pills.forEach((pill, index) => {
          pill.classList.toggle('is-laid', index < laid);
        });
      };
      applyLaid();

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        window.requestAnimationFrame(() => {
          ticking = false;
          // The trail starts empty: no dose falls until the reader moves.
          if (laid === 0 && window.scrollY < 60) return;

          const rect = prose.getBoundingClientRect();
          const progress = Math.min(1, Math.max(0, (window.innerHeight * 0.85 - rect.top) / rect.height));
          const due = Math.max(1, thresholds.filter((t) => progress >= t).length);

          if (due > laid) {
            laid = due;
            try { window.sessionStorage.setItem(LAID_KEY, String(laid)); } catch {}
            applyLaid();
          }
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      const lastPill = desktopTrail.querySelector('[data-index="7"]');
      if (lastPill instanceof HTMLButtonElement) {
        lastPill.addEventListener('click', () => {
          window.scrollTo({ top: 0, behavior: reducedMotion ? 'auto' : 'smooth' });
        });
      }
    }

    /* ---------- mobile: the pack pops, blister by blister ---------- */
    const mobileTrail = trailInstances.find((el) => el.dataset.variant === 'mobile');

    if (mobileTrail) {
      const POP_KEY = 'trail-blisters-popped';
      let popped: number[] = [];
      try { popped = JSON.parse(window.sessionStorage.getItem(POP_KEY) || '[]'); } catch {}

      const blisters = Array.from(mobileTrail.querySelectorAll<HTMLButtonElement>('[data-tt-blister]'));

      const applyPopped = () => {
        for (const blister of blisters) {
          const index = Number(blister.dataset.index);
          const isPopped = popped.includes(index);
          blister.classList.toggle('is-popped', isPopped);
          blister.setAttribute('aria-pressed', isPopped ? 'true' : 'false');
        }
      };
      applyPopped();

      for (const blister of blisters) {
        blister.addEventListener('click', () => {
          const index = Number(blister.dataset.index);
          if (popped.includes(index)) return;
          popped.push(index);
          try { window.sessionStorage.setItem(POP_KEY, JSON.stringify(popped)); } catch {}

          if (!reducedMotion) {
            blister.classList.add('is-popping');
            window.setTimeout(() => blister.classList.remove('is-popping'), 160);
          }
          applyPopped();
        });
      }
    }
  }
</script>

