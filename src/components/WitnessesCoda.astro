<script>
  /* Witnesses coda: the cat wakes when the reader reaches the end of the story,
     then holds its gaze on the moon. Taps get a small answer, nothing fancy. */
  const wcReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const wcCanHover = window.matchMedia('(hover: hover)').matches;
  const wcCats = document.querySelectorAll<HTMLElement>('[data-witnesses-cat]');

  for (const fig of wcCats) {
    let wcState: 'asleep' | 'awake' = 'asleep';
    let blinkIdleTimer = 0;
    let blinkReturnTimer = 0;

    const setState = (next: 'asleep' | 'awake' | 'blink') => {
      fig.dataset.state = next;
    };

    const scheduleIdleBlink = () => {
      window.clearTimeout(blinkIdleTimer);
      blinkIdleTimer = window.setTimeout(() => {
        if (wcState === 'awake' && !document.hidden && !wcReduceMotion) {
          setState('blink');
          blinkReturnTimer = window.setTimeout(() => setState('awake'), 240);
        }
        scheduleIdleBlink();
      }, 8000 + Math.random() * 9000);
    };

    const wake = () => {
      if (wcState === 'awake') return;
      wcState = 'awake';
      setState('awake');
      scheduleIdleBlink();
    };

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            window.setTimeout(wake, wcReduceMotion ? 0 : 1400);
            observer.disconnect();
          }
        }
      },
      { threshold: 0.55 }
    );
    observer.observe(fig);

    const hit = fig.querySelector<HTMLButtonElement>('.wc-cat-hit');
    hit?.addEventListener('click', () => {
      /* On touch there is no cursor to hover, so a tap is what lets the
         colour bleed through — and a second tap lets it recede. */
      if (!wcCanHover) fig.classList.toggle('is-lit');
      if (wcState === 'asleep') {
        /* A sleeping cat only flickers an ear. */
        fig.classList.remove('is-twitch');
        void fig.offsetWidth;
        fig.classList.add('is-twitch');
      } else {
        window.clearTimeout(blinkReturnTimer);
        setState('blink');
        blinkReturnTimer = window.setTimeout(() => setState('awake'), 280);
        scheduleIdleBlink();
      }
    });
  }

  /* The moon climbs a little as the reader makes their way down the story. */
  const wcMoonRise = document.querySelector<HTMLElement>('[data-witnesses-moon-rise]');
  if (wcMoonRise && !wcReduceMotion) {
    let wcRiseTicking = false;
    const wcUpdateRise = () => {
      wcRiseTicking = false;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      const progress = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      wcMoonRise.style.setProperty('--wc-rise', (16 - progress * 30).toFixed(2));
    };
    const wcOnScroll = () => {
      if (!wcRiseTicking) {
        wcRiseTicking = true;
        window.requestAnimationFrame(wcUpdateRise);
      }
    };
    window.addEventListener('scroll', wcOnScroll, { passive: true });
    wcUpdateRise();
  }
</script>

<style>
  .witnesses-coda {
    margin: 0;
    text-indent: 0;
  }

  /* ---------- The moon (desktop gutter companion) ---------- */

  .witnesses-coda--moon {
    display: none;
  }

  @media (min-width: 861px) {
    .witnesses-coda--moon {
      display: block;
      position: relative;
      width: min(100%, 280px);
      margin-top: clamp(30px, 6vw, 56px);
      pointer-events: none;
    }
  }

  .wc-moon-rise {
    transform: translateY(calc(var(--wc-rise, 16) * 1px));
  }

  .wc-moon-bob {
    position: relative;
    width: fit-content;
    margin: 0 auto;
    animation: wc-bob 6.5s ease-in-out infinite alternate;
  }

  .wc-moon-svg {
    display: block;
    width: clamp(88px, 9vw, 128px);
    height: auto;
    animation: wc-glow-pulse 7s ease-in-out infinite alternate;
  }

  .wc-cloud {
    position: absolute;
    pointer-events: none;
  }

  .wc-cloud svg {
    display: block;
    width: 100%;
    height: auto;
  }

  .wc-cloud--a {
    width: 30%;
    top: 16%;
    left: 0;
    opacity: 0.85;
    animation: wc-drift 22s linear infinite alternate;
  }

  .wc-cloud--b {
    width: 24%;
    top: 62%;
    left: 0;
    opacity: 0.7;
    animation: wc-drift 28s linear infinite alternate-reverse;
    animation-delay: -12s;
  }

  .wc-star {
    position: absolute;
    background: #e8e4da;
    opacity: 0.25;
    animation: wc-twinkle 4.4s ease-in-out infinite alternate;
  }

  .wc-star--1 { width: 2px; height: 2px; top: 6%;  left: 78%; animation-delay: -1.2s; }
  .wc-star--2 { width: 3px; height: 3px; top: 22%; left: 92%; animation-delay: -2.8s; }
  .wc-star--3 { width: 2px; height: 2px; top: 48%; left: 84%; animation-delay: -0.6s; }
  .wc-star--4 { width: 2px; height: 2px; top: -4%; left: 34%; animation-delay: -3.6s; }
  .wc-star--5 { width: 1px; height: 1px; top: 34%; left: 70%; animation-delay: -2.1s; }

  /* ---------- The cat (end of the story, all viewports) ---------- */

  .witnesses-coda--cat {
    position: relative;
    width: min(224px, 64vw);
    margin: clamp(3.5rem, 9vw, 6rem) auto 0;
  }

  .wc-cat-lift {
    transform-origin: 62% 100%;
    filter: grayscale(1);
    transition: filter 850ms ease;
  }

  /* The cat lives in the same grey world as everything else; its real
     warmth only bleeds through where the reader reaches for it — under
     the cursor on desktop, on a tap on touch. */
  @media (hover: hover) {
    .witnesses-coda--cat:hover .wc-cat-lift,
    .witnesses-coda--cat:focus-within .wc-cat-lift {
      filter: grayscale(0);
    }
  }

  .witnesses-coda--cat.is-lit .wc-cat-lift {
    filter: grayscale(0);
  }

  .witnesses-coda--cat svg {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
  }

  .wc-state {
    opacity: 0;
  }

  .witnesses-coda--cat[data-state='asleep'] .wc-state--sleep,
  .witnesses-coda--cat[data-state='awake'] .wc-state--awake,
  .witnesses-coda--cat[data-state='blink'] .wc-state--blink {
    opacity: 1;
  }

  .witnesses-coda--cat[data-state='asleep'] .wc-state--sleep {
    animation: wc-breathe 4.2s ease-in-out infinite;
    transform-origin: 50% 100%;
    transform-box: fill-box;
  }

  .witnesses-coda--cat.is-twitch .wc-cat-lift {
    animation: wc-twitch 360ms ease;
  }

  .wc-cat-hit {
    position: absolute;
    inset: 0;
    margin: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    touch-action: manipulation;
  }

  .wc-cat-hit:focus-visible {
    outline: 1px solid var(--border-strong);
    outline-offset: 4px;
  }

  @keyframes wc-breathe {
    0%, 100% { transform: scale(1, 1); }
    50% { transform: scale(1.008, 1.032); }
  }

  @keyframes wc-twitch {
    30% { transform: rotate(1.4deg) translateY(-1px); }
    62% { transform: rotate(-1deg); }
  }

  @keyframes wc-bob {
    from { transform: translateY(0); }
    to { transform: translateY(-5px); }
  }

  @keyframes wc-glow-pulse {
    from {
      filter: brightness(1) drop-shadow(0 0 7px rgba(232, 228, 214, 0.14));
    }
    to {
      filter: brightness(1.06) drop-shadow(0 0 26px rgba(232, 228, 214, 0.38));
    }
  }

  @keyframes wc-drift {
    from { transform: translateX(-20%); }
    to { transform: translateX(240%); }
  }

  @keyframes wc-twinkle {
    from { opacity: 0.12; }
    to { opacity: 0.75; }
  }

  @media (prefers-reduced-motion: reduce) {
    .wc-moon-svg,
    .wc-moon-bob,
    .wc-cloud,
    .wc-star,
    .witnesses-coda--cat[data-state='asleep'] .wc-state--sleep,
    .witnesses-coda--cat.is-twitch .wc-cat-lift {
      animation: none;
    }

    .wc-moon-rise {
      transform: none;
    }

    .wc-star {
      opacity: 0.4;
    }

    /* The warmth still bleeds through, just without the slow fade. */
    .wc-cat-lift {
      transition: none;
    }
  }
</style>

<style is:global>
  /* Witnesses: make the cover slot the sticky container so the moon rides
