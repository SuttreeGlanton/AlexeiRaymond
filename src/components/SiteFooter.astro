---
import { site } from '../lib/data';
import { withBase } from '../lib/paths';

const year = new Date().getFullYear();

const footerLinks = [
  { label: 'Cycles', href: withBase('') },
  { label: 'Selected', href: withBase('selected/') },
  { label: 'Chronology', href: withBase('chronology/') },
  { label: 'About', href: withBase('about/') },
  { label: 'Elsewhere', href: withBase('elsewhere/') }
];

const socialLinks = site.socials.flatMap((social) => {
  if (typeof social === 'string') return [];

  const label = social.label ?? social.name ?? '';
  const href = social.url ?? social.href ?? '';

  return href && (label === 'X' || label === 'Instagram')
    ? [{ label, href }]
    : [];
});
---

<footer class="site-footer">
  <div class="page-shell footer-inner">
    <span class="footer-mark">&copy; {year} {site.author}</span>

    <nav class="footer-socials" aria-label="Social links">
      {socialLinks.map((item) => (
        <a
          class="footer-social-link"
          href={item.href}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${site.author} on ${item.label}`}
          title={item.label}
        >
          {item.label === 'X' ? (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z" />
            </svg>
          ) : (
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <rect x="3" y="3" width="18" height="18" rx="5" fill="none" stroke="currentColor" stroke-width="1.7" />
              <circle cx="12" cy="12" r="4.25" fill="none" stroke="currentColor" stroke-width="1.7" />
              <circle cx="17.35" cy="6.65" r="1" />
            </svg>
          )}
        </a>
      ))}
    </nav>

    <nav class="footer-nav" aria-label="Footer navigation">
      {footerLinks.map((item) => (
        <a href={item.href}>{item.label}</a>
      ))}
      <a href="#">Back to top &uarr;</a>
    </nav>
  </div>
</footer>
