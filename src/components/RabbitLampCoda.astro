<style>
  .rabbitlamp-coda {
    margin: 0;
    text-indent: 0;
    display: grid;
    justify-items: center;
  }

  .rabbitlamp-coda--desktop {
    margin-top: 26px;
  }

  .rabbitlamp-coda--mobile {
    margin: clamp(4rem, 10vw, 6.5rem) 0 0;
  }

  .rl-lamp {
    position: relative;
    display: block;
    width: 118px;
    margin: 0;
    border: 0;
    padding: 0;
    background: transparent;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
    touch-action: manipulation;
  }

  .rl-lamp:focus-visible {
    outline: 1px solid var(--border-strong);
    outline-offset: 6px;
    border-radius: 8px;
  }

  .rl-svg {
    position: relative;
    display: block;
    width: 100%;
    height: auto;
    z-index: 1;
  }

  .rl-layer {
    transition: opacity 340ms ease;
  }

  .rl-red,
  .rl-gold {
    opacity: 0;
  }

  [data-lit='on']:not([data-gold]) .rl-red {
    opacity: 1;
  }

  [data-lit='on'][data-gold] .rl-gold {
    opacity: 1;
  }

  /* The glow is not a painted circle but a living thing: three unequal
     auras, each swaying on its own time, like the light of a candle.
     The golden sunrise burns visibly stronger than the red. */
  .rl-halo {
    position: absolute;
    inset: -20%;
    z-index: 0;
    border-radius: 50%;
    opacity: 0;
    transition: opacity 420ms ease;
    background: radial-gradient(circle at 50% 60%, rgba(246, 94, 66, 0.26) 0%, rgba(246, 94, 66, 0.09) 46%, transparent 70%);
    pointer-events: none;
  }

  .rl-halo::before,
  .rl-halo::after {
    content: "";
    position: absolute;
    border-radius: 50%;
  }

  .rl-halo::before {
    inset: 6% 2% 0;
    background: radial-gradient(circle at 46% 64%, rgba(255, 138, 102, 0.22) 0%, transparent 58%);
    animation: rl-candle-sway 5.3s ease-in-out infinite;
  }

  .rl-halo::after {
    inset: 18% 14% 8%;
    background: radial-gradient(circle at 52% 58%, rgba(255, 192, 150, 0.3) 0%, transparent 55%);
    animation: rl-candle-breathe 3.9s ease-in-out infinite;
  }

  [data-lit='on'] .rl-halo {
    opacity: 1;
    animation: rl-candle-drift 6.7s ease-in-out infinite;
  }

  [data-lit='on'][data-gold] .rl-halo {
    inset: -27%;
    background: radial-gradient(circle at 50% 60%, rgba(255, 201, 94, 0.42) 0%, rgba(255, 190, 80, 0.17) 46%, transparent 72%);
  }

  [data-lit='on'][data-gold] .rl-halo::before {
    background: radial-gradient(circle at 46% 64%, rgba(255, 228, 154, 0.36) 0%, transparent 58%);
  }

  [data-lit='on'][data-gold] .rl-halo::after {
    background: radial-gradient(circle at 52% 58%, rgba(255, 247, 214, 0.52) 0%, transparent 55%);
  }

  @keyframes rl-candle-drift {
    0%, 100% { transform: translate(0, 0) scale(1); }
    35% { transform: translate(1%, 1.5%) scale(1.015); }
    70% { transform: translate(-1.5%, -1%) scale(0.99); }
  }

  @keyframes rl-candle-sway {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.85; }
    23% { transform: translate(-2.5%, 1%) scale(1.03); opacity: 1; }
    41% { transform: translate(1.5%, -1.5%) scale(0.98); opacity: 0.68; }
    66% { transform: translate(2.5%, 1%) scale(1.04); opacity: 0.95; }
    84% { transform: translate(-1%, -0.5%) scale(1); opacity: 0.78; }
  }

  @keyframes rl-candle-breathe {
    0%, 100% { transform: scale(1); opacity: 0.75; }
    30% { transform: scale(1.06) translate(1%, -1%); opacity: 1; }
    52% { transform: scale(0.96); opacity: 0.58; }
    78% { transform: scale(1.03) translate(-1.5%, 0.5%); opacity: 0.9; }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-lit='on'] .rl-halo,
    .rl-halo::before,
    .rl-halo::after {
      animation: none;
    }
  }

  /* the waver: quick dips scheduled by script */
  .rabbitlamp-coda[data-lit='on'].is-dim:not([data-gold]) .rl-red,
  .rabbitlamp-coda[data-lit='on'][data-gold].is-dim .rl-gold {
    opacity: 0.3;
    transition: opacity 90ms ease;
  }

  .is-dim .rl-halo {
    opacity: 0.32;
    transition: opacity 90ms ease;
  }

  /* reduced motion: a slow, gentle breathing instead of flicker */
  .is-waver-gentle .rl-red,
  .is-waver-gentle .rl-gold {
    animation: rl-gentle 3.8s ease-in-out infinite;
  }

  @keyframes rl-gentle {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.68; }
  }

  /* night refusal: the faintest failed ember, then nothing */
  .is-refuse .rl-red {
    opacity: 0.07;
    transition: opacity 60ms ease;
  }

  .rl-status {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  @media (max-width: 860px) {
    .rabbitlamp-coda--desktop { display: none; }
  }

  @media (min-width: 861px) {
    .rabbitlamp-coda--mobile { display: none; }
  }
</style>
