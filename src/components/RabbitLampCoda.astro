      <path fill="rgb(255,247,214)" d="M19 47h3v1h-3zM27 47h3v1h-3zM18 48h13v1h-13zM19 49h11v1h-11zM23 60h3v1h-3zM22 61h5v1h-5zM22 62h5v1h-5zM22 63h5v1h-5zM22 64h5v1h-5zM23 65h3v1h-3z"/>
