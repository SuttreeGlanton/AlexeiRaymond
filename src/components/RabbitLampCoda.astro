  <span class="rl-status" aria-live="polite" data-rl-status></span>
</figure>

<script>
  const rlFigs = Array.from(document.querySelectorAll<HTMLElement>('[data-rabbitlamp]'));

  if (rlFigs.length > 0) {
    const rlReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const prose = document.querySelector<HTMLElement>('.archive-prose');

    const KEY = 'truth-lamp';
    let store: { gold?: boolean; user?: 'auto' | 'on' | 'off' } = {};
    try { store = JSON.parse(window.sessionStorage.getItem(KEY) || '{}'); } catch {}
    let gold = Boolean(store.gold);
    let userWants: 'auto' | 'on' | 'off' = store.user ?? 'auto';
    const save = () => {
      try { window.sessionStorage.setItem(KEY, JSON.stringify({ gold, user: userWants })); } catch {}
    };

    /* phases: opening -> night -> day -> waver -> day */
    type Phase = 'opening' | 'night' | 'day' | 'waver';
    let phase: Phase = 'opening';

    const effectiveOn = (): boolean => {
      /* after the sunrise transformation the dark has lost its power:
         the lamp stays lit even beside the night-terror passage */
      if (phase === 'night' && !gold) return false;
      /* With no reader override, morning relights the lamp after the forced
         darkness and keeps it available for the later confrontation. */
      if (userWants === 'auto') return phase !== 'night';
      return userWants === 'on';
    };

    let flickerTimer = 0;

    const broadcastState = () => {
      window.dispatchEvent(new CustomEvent('truth-lamp-state', {
        detail: { on: effectiveOn(), gold, phase }
      }));
    };

    const setDim = (dim: boolean) => {
      for (const fig of rlFigs) fig.classList.toggle('is-dim', dim);
      window.dispatchEvent(new CustomEvent('truth-lamp-dim', { detail: { dim } }));
    };

    const applyState = () => {
      const on = effectiveOn();
      for (const fig of rlFigs) {
        fig.dataset.lit = on ? 'on' : 'off';
        if (gold) fig.dataset.gold = 'true';
        else delete fig.dataset.gold;
        fig.dataset.phase = phase;
        const hit = fig.querySelector<HTMLButtonElement>('[data-rl-hit]');
        hit?.setAttribute('aria-pressed', on ? 'true' : 'false');
      }
      scheduleFlicker();
      broadcastState();
    };

    /* ---- the waver: restrained, irregular dips while lit ---- */
    const scheduleFlicker = () => {
      window.clearTimeout(flickerTimer);
      setDim(false);

      const wavering = phase === 'waver' && effectiveOn();
      for (const fig of rlFigs) fig.classList.toggle('is-waver-gentle', wavering && rlReducedMotion);
      if (!wavering || rlReducedMotion) return;

      const dip = () => {
        if (phase !== 'waver' || !effectiveOn()) return;
        setDim(true);
        window.setTimeout(() => {
          setDim(false);
          /* occasionally a second, shorter falter close behind */
          if (Math.random() < 0.3) {
            window.setTimeout(() => {
              if (phase !== 'waver' || !effectiveOn()) return;
              setDim(true);
              window.setTimeout(() => {
                setDim(false);
              }, 90 + Math.random() * 80);
            }, 140 + Math.random() * 120);
          }
        }, 130 + Math.random() * 220);
        flickerTimer = window.setTimeout(dip, 950 + Math.random() * 1400);
      };
      flickerTimer = window.setTimeout(dip, 600 + Math.random() * 900);
    };

    /* ---- lamp button ---- */
    const say = (text: string) => {
      for (const fig of rlFigs) {
        const status = fig.querySelector<HTMLElement>('[data-rl-status]');
        if (status) status.textContent = text;
      }
    };

    const toggleLamp = (fig?: HTMLElement) => {
      if (phase === 'night' && !gold) {
        /* the dark refuses: a failed ember, nothing more */
        if (!rlReducedMotion) {
          if (fig) {
            fig.classList.remove('is-refuse');
            void fig.offsetWidth;
            fig.classList.add('is-refuse');
            window.setTimeout(() => fig.classList.remove('is-refuse'), 300);
          }
        }
        window.dispatchEvent(new CustomEvent('truth-lamp-refused'));
        say('The dark refuses the light.');
        return;
      }
      userWants = effectiveOn() ? 'off' : 'on';
      save();
      applyState();
      say(userWants === 'on' ? 'The night-light is on.' : 'The night-light is off.');
    };

    for (const fig of rlFigs) {
      const hit = fig.querySelector<HTMLButtonElement>('[data-rl-hit]');
      hit?.addEventListener('click', () => toggleLamp(fig));
    }

    window.addEventListener('truth-lamp-toggle', () => toggleLamp());
    window.addEventListener('truth-lamp-request-state', broadcastState);

    /* ---- story markers drive the phase on both desktop and mobile ---- */
    if (prose) {
      const MARKERS: Array<[string, Phase]> = [
        ['and extinguished it', 'night'],
        ['Hours later, when the morning', 'day'],
        ['You didn\u2019t throw it away', 'waver'],
        ['guide him home', 'day']
      ];
      const markerEls: Array<[HTMLElement, Phase]> = [];
      const paras = Array.from(prose.querySelectorAll<HTMLElement>('p'));
      for (const [needle, ph] of MARKERS) {
        const el = paras.find((p) => (p.textContent || '').includes(needle));
        if (el) markerEls.push([el, ph]);
      }

      let ticking = false;
      const update = () => {
        ticking = false;
        const focus = window.innerHeight * 0.6;
        let next: Phase = 'opening';
        for (const [el, ph] of markerEls) {
          if (el.getBoundingClientRect().top < focus) next = ph;
        }
        if (next !== phase) {
          phase = next;
          applyState();
        }
      };
      window.addEventListener('scroll', () => {
        if (!ticking) {
          ticking = true;
          window.requestAnimationFrame(update);
        }
      }, { passive: true });
      update();
    }

    /* ---- "Charging, charging." — the one-time golden trigger ---- */
    const PHRASE = 'Charging, charging.';
    if (prose) {
      const walker = document.createTreeWalker(prose, NodeFilter.SHOW_TEXT, {
        acceptNode(node) {
          if (!node.nodeValue?.includes(PHRASE)) return NodeFilter.FILTER_REJECT;
          const parent = (node as Text).parentElement;
          if (!parent || parent.closest('button, a, script, style')) return NodeFilter.FILTER_REJECT;
          return NodeFilter.FILTER_ACCEPT;
        }
      });
      const textNode = walker.nextNode() as Text | null;
      if (textNode) {
        const text = textNode.nodeValue ?? '';
        const at = text.indexOf(PHRASE);
        const frag = document.createDocumentFragment();
        frag.append(document.createTextNode(text.slice(0, at)));
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'rl-charging';
        /* Firefox paints a button's text in an anonymous inner frame, so
           background-clip: text must live on a real span inside it */
        const btnText = document.createElement('span');
        btnText.className = 'rl-charging-text';
        btnText.textContent = PHRASE;
        btn.append(btnText);
        btn.setAttribute('aria-label', 'Charging, charging \u2014 let the morning through');
        btn.setAttribute('aria-pressed', 'false');
        frag.append(btn);
        frag.append(document.createTextNode(text.slice(at + PHRASE.length)));
        textNode.parentNode?.replaceChild(frag, textNode);

        const charge = () => {
          gold = true;
          if (userWants !== 'off') userWants = 'on';
          btn.classList.add('is-charged');
          btn.setAttribute('aria-pressed', 'true');
          save();
          applyState();
          window.dispatchEvent(new CustomEvent('truth-lamp-charged'));
          say('The light turns to sunrise.');
        };
        if (gold) {
          btn.classList.add('is-charged');
          btn.setAttribute('aria-pressed', 'true');
        }
        btn.addEventListener('click', () => {
          if (!gold) charge();
        });
      }
    }

    applyState();
  }
</script>

