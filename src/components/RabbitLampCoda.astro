---
/* Truth, or Its Evidence: the rabbit night-light keeps watch beside the
   story. It is lit red for the opening comfort; the night takes it and
   will not give it back; morning returns it to the reader's hand; it
   wavers when the boy confronts his mother; and the final words —
   "Charging, charging." — turn its glow to sunrise gold for good.
   Desktop shows the full figure; the mobile header uses the same state and
   behavior, cropped down to the rabbit's head. */
interface Props {
  variant: 'desktop' | 'mobile';
}

const { variant } = Astro.props;
