---
import { Picture } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import CycleIcon from './CycleIcon.astro';
import type { Cycle } from '../lib/data';
import { cycleTeaser } from '../lib/data';
import { withBase } from '../lib/paths';

interface Props {
  cycle: Cycle;
  image: ImageMetadata;
}

const { cycle, image } = Astro.props;
const bannerWidths = [640, 768, 960, 1280, 1440, 1600, 1920, 2048];
const teaser = cycleTeaser(cycle);
const bindTeaserEnding = cycle.id === 'the-real' || cycle.id === 'valentines-star';
const teaserEndingMatch = bindTeaserEnding ? teaser.match(/^(.*\S)\s+(\S+\s+\S+)$/) : null;
const teaserLead = teaserEndingMatch?.[1] ?? teaser;
const teaserEnding = teaserEndingMatch?.[2] ?? '';
const dreamsTeaserMatch = cycle.id === 'dreams' ? teaser.match(/^(.*?)(bubbling up\.)(.*)$/) : null;
---

<section
  class="cycle-hero"
  aria-labelledby="cycle-title"
  data-cycle-color-reveal
  data-cycle-id={cycle.id}
>
  <div class="cycle-hero-media" aria-hidden="true">
    <Picture
      class="cycle-hero-image cycle-hero-image--mono"
      src={image}
      alt=""
      widths={bannerWidths}
      width={2048}
      sizes="100vw"
      formats={['avif']}
      fallbackFormat="webp"
      quality={55}
      priority
    />
    <Picture
      class="cycle-hero-image cycle-hero-image--color"
      src={image}
      alt=""
      widths={bannerWidths}
      width={2048}
      sizes="100vw"
      formats={['avif']}
      fallbackFormat="webp"
      quality={55}
      loading="eager"
      decoding="async"
    />
    <div class="cycle-hero-scrim"></div>
  </div>

  <div class="page-shell cycle-hero-content">
    <a class="back-link" href={withBase('')}>
      <span class="back-link-arrow" aria-hidden="true">&larr;</span>
      <span class="back-link-label">All cycles</span>
    </a>
    <h1 class="cycle-title" id="cycle-title"><CycleIcon id={cycle.id} />{cycle.name}</h1>
    {teaser && (
      <p class="cycle-intro">
        {dreamsTeaserMatch ? (
          <>{dreamsTeaserMatch[1]}<span class="cycle-intro-ending">{dreamsTeaserMatch[2]}</span>{dreamsTeaserMatch[3]}</>
        ) : (
          <>{teaserLead}{teaserEnding && <> <span class="cycle-intro-ending">{teaserEnding}</span></>}</>
        )}
      </p>
    )}
  </div>
</section>

<script>
  /* Desktop pointer flashlight; touch layouts show the complete color image. */
  const cycleHero = document.querySelector<HTMLElement>('[data-cycle-color-reveal]');
  const canRevealCycle =
    cycleHero &&
    window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
    !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (canRevealCycle && cycleHero) {
    const heroEl = cycleHero;
    let frame = 0;

    const moveCycleReveal = (event: PointerEvent) => {
      const rect = heroEl.getBoundingClientRect();
      const x = ((event.clientX - rect.left) / rect.width) * 100;
      const y = ((event.clientY - rect.top) / rect.height) * 100;

      cancelAnimationFrame(frame);
      frame = requestAnimationFrame(() => {
        heroEl.style.setProperty('--reveal-x', `${x}%`);
        heroEl.style.setProperty('--reveal-y', `${y}%`);
        heroEl.classList.add('is-color-reveal-active');
      });
    };

    heroEl.addEventListener('pointermove', moveCycleReveal);
    heroEl.addEventListener('pointerenter', moveCycleReveal);
    heroEl.addEventListener('pointerleave', () => {
      heroEl.classList.remove('is-color-reveal-active');
    });
  }
</script>

<style>
  .cycle-hero {
    --reveal-x: 50%;
    --reveal-y: 50%;
    position: relative;
    isolation: isolate;
    display: grid;
    align-items: end;
    min-height: clamp(260px, 28vw, 390px);
    margin-bottom: clamp(24px, 3.5vw, 42px);
    overflow: hidden;
  }

  .cycle-hero-media {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .cycle-hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: 50% 50%;
  }

  .cycle-hero-image--mono {
    filter: grayscale(1) brightness(0.48) contrast(1.06);
  }

  .cycle-hero-image--color {
    opacity: 0;
    filter: brightness(0.98) contrast(1.03) saturate(1.1);
    pointer-events: none;
    transition: opacity 160ms ease;
    will-change: opacity, mask-image, -webkit-mask-image;
    -webkit-mask-image: radial-gradient(
      circle at var(--reveal-x) var(--reveal-y),
      #000 0,
      #000 120px,
      rgba(0, 0, 0, 0.78) 230px,
      rgba(0, 0, 0, 0.36) 340px,
      transparent 460px
    );
    mask-image: radial-gradient(
      circle at var(--reveal-x) var(--reveal-y),
      #000 0,
      #000 120px,
      rgba(0, 0, 0, 0.78) 230px,
      rgba(0, 0, 0, 0.36) 340px,
      transparent 460px
    );
  }

  .cycle-hero.is-color-reveal-active .cycle-hero-image--color {
    opacity: 1;
  }

  .cycle-hero-scrim {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 10, 10, 0.14) 0%,
      rgba(10, 10, 10, 0.12) 38%,
      rgba(10, 10, 10, 0.66) 78%,
      var(--bg) 100%
    );
    pointer-events: none;
  }

  .cycle-hero-content {
    position: relative;
    z-index: 1;
    display: flex;
    justify-content: flex-end;
    flex-direction: column;
    padding-top: clamp(76px, 9vw, 128px);
    padding-bottom: clamp(30px, 4vw, 48px);
    -webkit-user-select: none;
    user-select: none;
  }

  .cycle-hero .back-link {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 0.55em;
    width: fit-content;
    margin-bottom: clamp(14px, 2vw, 24px);
    color: rgba(241, 239, 233, 0.96);
    font-weight: 600;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.95);
    transition: color 180ms ease;
  }

  .cycle-hero .back-link-label {
    border-bottom: 1px solid transparent;
    line-height: 1.2;
    transition: border-color 180ms ease;
  }

  .cycle-hero .back-link:hover,
  .cycle-hero .back-link:focus-visible {
    border-color: transparent;
    color: var(--text);
  }

  .cycle-hero .back-link:hover .back-link-label,
  .cycle-hero .back-link:focus-visible .back-link-label {
    border-bottom-color: currentColor;
  }

  .cycle-hero .cycle-title {
    max-width: 100%;
    margin-top: 0;
    color: var(--text);
    font-size: clamp(2.75rem, 7.25vw, 6.75rem);
    text-shadow:
      0 2px 3px rgba(0, 0, 0, 0.95),
      0 4px 24px rgba(0, 0, 0, 0.88);
  }

  .cycle-hero .cycle-intro {
    max-width: 660px;
    margin-top: 14px;
    color: var(--text);
    font-weight: 500;
    text-shadow:
      0 1px 2px rgba(0, 0, 0, 1),
      0 3px 16px rgba(0, 0, 0, 0.98),
      0 0 32px rgba(0, 0, 0, 0.9);
  }

  .cycle-intro-ending {
    white-space: nowrap;
  }

  @media (hover: none), (pointer: coarse) {
    .cycle-hero-image--mono {
      display: none;
    }

    .cycle-hero-image--color {
      opacity: 1;
      filter: none;
      -webkit-mask-image: none;
      mask-image: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .cycle-hero-image--color {
      transition: none;
    }
  }

  @media (max-width: 900px) {
    .cycle-hero {
      min-height: clamp(250px, 52vw, 340px);
      margin-bottom: 24px;
    }

    .cycle-hero .back-link {
      margin-bottom: 14px;
      color: rgba(241, 239, 233, 0.96);
      text-shadow: 0 1px 8px rgba(0, 0, 0, 0.95);
    }

    .cycle-hero .cycle-title {
      font-size: clamp(2.55rem, 10vw, 4.15rem);
      text-shadow:
        0 2px 3px rgba(0, 0, 0, 0.95),
        0 4px 24px rgba(0, 0, 0, 0.88);
    }

    .cycle-hero .cycle-intro {
      max-width: 34ch;
      margin-top: 12px;
      font-size: 1rem;
      text-shadow:
        0 1px 2px rgba(0, 0, 0, 1),
        0 3px 16px rgba(0, 0, 0, 0.98),
        0 0 32px rgba(0, 0, 0, 0.9);
    }
  }

  @media (max-width: 640px) {
    .cycle-hero {
      min-height: clamp(260px, 76vw, 340px);
      margin-bottom: 24px;
    }

    .cycle-hero-content {
      padding-top: 76px;
      padding-bottom: 28px;
    }

    .cycle-hero .cycle-title {
      font-size: clamp(2.45rem, 12.5vw, 4rem);
    }

    .cycle-hero[data-cycle-id='valentines-star'] .cycle-title {
      font-size: clamp(1.95rem, 9vw, 3rem);
      white-space: nowrap;
    }

    .cycle-hero-image--mono {
      display: none;
    }

    .cycle-hero-image--color {
      display: block;
      opacity: 1;
      filter: none;
      -webkit-mask-image: none;
      mask-image: none;
    }

    .cycle-hero-scrim {
      display: block;
      background: linear-gradient(
        180deg,
        rgba(10, 10, 10, 0.58) 0%,
        rgba(10, 10, 10, 0.25) 38%,
        rgba(10, 10, 10, 0.58) 76%,
        var(--bg) 100%
      );
    }
  }
</style>
