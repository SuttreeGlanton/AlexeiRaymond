---
import { cycles, site } from '../lib/data';
import { withBase } from '../lib/paths';
import HeaderCoda from './HeaderCoda.astro';

interface Props {
  headerCoda?: 'moon' | 'counter' | 'pills' | 'eyes' | 'clock' | 'rabbit';
}

const { headerCoda } = Astro.props;

const currentPath = Astro.url.pathname;
const homeHref = withBase('');
const currentWithoutTrailing = currentPath.replace(/\/$/, '');
const homeWithoutTrailing = homeHref.replace(/\/$/, '');
const isHome = currentWithoutTrailing === homeWithoutTrailing;
const cycleOverviewHref = `${homeHref}#cycles-title`;

/* Brand monogram parts: "Alexei Raymond" -> A + lexei + R + aymond, so the
   header can fold the full name down to the "AR" initials on the homepage. */
const [brandFirst = '', brandLast = ''] = site.author.split(' ');
const brandParts = {
  firstInitial: brandFirst.charAt(0),
  firstRest: brandFirst.slice(1),
  lastInitial: brandLast.charAt(0),
  lastRest: brandLast.slice(1)
};

const cycleNavItems = cycles.filter((cycle) => !cycle.disabled).map((cycle) => ({
  label: cycle.name,
  href: withBase(`cycles/${cycle.id}/`),
  active: currentPath.startsWith(withBase(`cycles/${cycle.id}/`))
}));

const navItems = [
  {
    label: 'Cycles',
    href: cycleOverviewHref,
    active: isHome || currentPath.startsWith(withBase('cycles/'))
  },
  {
    label: 'Selected',
    href: withBase('selected/'),
    active: currentPath.startsWith(withBase('selected/'))
  },
  {
    label: 'Chronology',
    href: withBase('chronology/'),
    active: currentPath.startsWith(withBase('chronology/'))
  },
  {
    label: 'About',
    href: withBase('about/'),
    active: currentPath.startsWith(withBase('about/'))
  },
  {
    label: 'Elsewhere',
    href: withBase('elsewhere/'),
    active: currentPath.startsWith(withBase('elsewhere/'))
  }
];

const desktopNavItems = [
  ...navItems.filter((item) => item.label !== 'Cycles'),
  ...navItems.filter((item) => item.label === 'Cycles')
];
---

<header class="site-header" data-site-header>
  <div class="page-shell header-inner">
    <a class="brand" href={homeHref} data-site-brand><span class="brand-initial">{brandParts.firstInitial}</span><span class="brand-fold">{brandParts.firstRest}&nbsp;</span><span class="brand-initial">{brandParts.lastInitial}</span><span class="brand-fold">{brandParts.lastRest}</span></a>

    {headerCoda && (
      <div class="header-coda-slot">
        <HeaderCoda type={headerCoda} />
      </div>
    )}

    <button
      class="mobile-menu-toggle"
      type="button"
      data-mobile-menu-toggle
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
    >
      <span class="mobile-menu-label" data-mobile-menu-label>Menu</span>
      <span class="mobile-menu-icon" aria-hidden="true">
        <span></span>
        <span></span>
        <span></span>
      </span>
    </button>

    <nav class="main-nav" aria-label="Main navigation">
      {desktopNavItems.map((item) => (
        item.label === 'Cycles' ? (
          <div class="nav-cycle-menu">
            <a class="nav-link" href={item.href} aria-current={item.active ? 'page' : undefined}>
              <span>{item.label}</span>
            </a>
            <div class="nav-cycle-panel" aria-label="Cycle navigation">
              {cycleNavItems.map((cycle) => (
                <a href={cycle.href} aria-current={cycle.active ? 'page' : undefined}>{cycle.label}</a>
              ))}
            </div>
          </div>
        ) : (
          <a class="nav-link" href={item.href} aria-current={item.active ? 'page' : undefined}>
            <span>{item.label}</span>
          </a>
        )
      ))}
    </nav>
  </div>

  <nav class="mobile-menu-panel" id="mobile-menu-panel" data-mobile-menu-panel aria-label="Mobile navigation" hidden>
    <div class="mobile-menu-view" data-mobile-menu-main>
      <span class="mobile-menu-kicker">Navigation</span>
      {navItems.map((item) => (
        item.label === 'Cycles' ? (
          <button
            class={`mobile-menu-link mobile-menu-drilldown${item.active ? ' is-active' : ''}`}
            type="button"
            data-mobile-cycles-open
            aria-expanded="false"
            aria-controls="mobile-cycle-view"
          >
            <span class="mobile-menu-link-text">{item.label}</span>
            <span class="mobile-menu-chevron" aria-hidden="true">›</span>
          </button>
        ) : (
          <a class="mobile-menu-link" href={item.href} aria-current={item.active ? 'page' : undefined}>
            <span class="mobile-menu-link-text">{item.label}</span>
          </a>
        )
      ))}
    </div>

    <div
      class="mobile-menu-view mobile-cycle-view"
      id="mobile-cycle-view"
      data-mobile-cycle-view
      aria-label="Cycle navigation"
      hidden
    >
      <div class="mobile-cycle-heading">
        <button class="mobile-cycle-back" type="button" data-mobile-cycles-back>
          <span aria-hidden="true">←</span>
          <span>Back</span>
        </button>
        <span class="mobile-menu-kicker">Cycles</span>
      </div>

      <div class="mobile-cycle-list">
        {cycleNavItems.map((cycle) => (
          <a class="mobile-cycle-link" href={cycle.href} aria-current={cycle.active ? 'page' : undefined}>
            {cycle.label}
          </a>
        ))}
      </div>

      <a class="mobile-cycle-overview" href={cycleOverviewHref} aria-current={isHome ? 'page' : undefined}>
        <span>View all cycles</span>
      </a>
    </div>
  </nav>
</header>

<script>
  (() => {
    const header = document.querySelector<HTMLElement>('[data-site-header]');
    const button = document.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-mobile-menu-panel]');
    const label = document.querySelector<HTMLElement>('[data-mobile-menu-label]');
    const mainView = document.querySelector<HTMLElement>('[data-mobile-menu-main]');
    const cycleView = document.querySelector<HTMLElement>('[data-mobile-cycle-view]');
    const cycleOpen = document.querySelector<HTMLButtonElement>('[data-mobile-cycles-open]');
    const cycleBack = document.querySelector<HTMLButtonElement>('[data-mobile-cycles-back]');

    if (!header || !button || !panel || !label || !mainView || !cycleView || !cycleOpen || !cycleBack) return;

    function setCycleView(open: boolean) {
      if (!mainView || !cycleView || !cycleOpen) return;
      mainView.hidden = open;
      cycleView.hidden = !open;
      cycleOpen.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    function setOpen(open: boolean) {
      if (!header || !button || !panel || !label) return;
      header.classList.toggle('is-mobile-menu-open', open);
      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.hidden = !open;
      label.textContent = open ? 'Close' : 'Menu';
      setCycleView(false);
    }

    button.addEventListener('click', (event) => {
      event.stopPropagation();
      setOpen(button.getAttribute('aria-expanded') !== 'true');
    });

    cycleOpen.addEventListener('click', (event) => {
      event.stopPropagation();
      setCycleView(true);
      cycleBack.focus();
    });

    cycleBack.addEventListener('click', (event) => {
      event.stopPropagation();
      setCycleView(false);
      cycleOpen.focus();
    });

    panel.addEventListener('click', (event) => {
      event.stopPropagation();
      if (event.target instanceof Element && event.target.closest('a')) setOpen(false);
    });

    document.addEventListener('click', () => {
      if (button.getAttribute('aria-expanded') === 'true') setOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key !== 'Escape' || button.getAttribute('aria-expanded') !== 'true') return;

      if (!cycleView.hidden) {
        setCycleView(false);
        cycleOpen.focus();
        return;
      }

      setOpen(false);
      button.focus();
    });

    window.addEventListener('resize', () => {
      if (!window.matchMedia('(max-width: 640px)').matches) setOpen(false);
    });
  })();
</script>

<script>
  /* Homepage only: while the giant hero H1 (the same name) is on screen, the
     header brand stays folded to its "AR" monogram; it unfolds to the full
     name once the H1 scrolls away. Armed by JS via [data-brand-reveal] so
     no-JS visitors always see the full name. */
  (() => {
    const brand = document.querySelector<HTMLElement>('[data-site-brand]');
    const homeTitle = document.getElementById('home-title');

    if (!brand || !homeTitle || !('IntersectionObserver' in window)) return;

    brand.setAttribute('data-brand-reveal', '');

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          brand.classList.toggle('brand-is-open', !entry.isIntersecting);
        });
      },
      { rootMargin: '-64px 0px 0px 0px', threshold: 0 }
    );

    observer.observe(homeTitle);
  })();
</script>

<style>
  /* Header coda slot: mobile only. Once the reader scrolls past the story
     title, the story's miniature coda rises over the brand slot and the name
     steps aside (the header-coda-on class is toggled from HeaderCoda's
     script). No-JS and desktop visitors always keep the plain brand. */
  .header-coda-slot {
    display: none;
  }

  @media (max-width: 640px) {
    .header-inner {
      position: relative;
    }

    .header-coda-slot {
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      display: flex;
      align-items: center;
      pointer-events: none;
    }

    .brand {
      transition: opacity 300ms ease, visibility 300ms ease;
    }

    .header-coda-on .brand {
      opacity: 0;
      visibility: hidden;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .brand {
      transition: none;
    }
  }
</style>
