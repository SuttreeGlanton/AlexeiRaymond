---
import { cycles, site } from '../lib/data';
import { withBase } from '../lib/paths';

const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navItems = [
  { href: withBase(''), label: 'Home', match: 'home' },
  { href: withBase('selected/'), label: 'Selected', match: 'selected' },
  { href: withBase('chronology/'), label: 'Chronology', match: 'chronology' },
  { href: withBase('about/'), label: 'About', match: 'about' },
  { href: withBase('elsewhere/'), label: 'Elsewhere', match: 'elsewhere' }
];
const enabledCycles = cycles.filter((cycle) => !cycle.disabled);

function isActive(match: string) {
  if (match === 'home') return currentPath === `${base}/`;
  return currentPath.startsWith(`${base}/${match}`);
}

function isCycleNavActive() {
  return currentPath.includes(`${base}/cycles/`);
}
---

<header class="site-header" data-site-header>
  <nav class="site-nav" aria-label="Primary">
    <a class="site-wordmark" href={withBase('')} aria-current={isActive('home') ? 'page' : undefined}>
      <span class="site-wordmark-text">{site.author}</span>
    </a>

    <button
      class="mobile-menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu-panel"
      data-mobile-menu-toggle
    >
      <span class="mobile-menu-toggle-bars" aria-hidden="true"></span>
      <span class="mobile-menu-toggle-label" data-mobile-menu-label>Menu</span>
    </button>

    <div class="site-nav-links" aria-label="Sections">
      {navItems.map((item) => (
        <a href={item.href} aria-current={isActive(item.match) ? 'page' : undefined}>{item.label}</a>
      ))}
    </div>

    <div class="site-nav-panel" id="mobile-menu-panel" hidden data-mobile-menu-panel>
      <div class="site-nav-panel-view" data-mobile-menu-main>
        {navItems.map((item) => (
          <a class="site-nav-panel-link" href={item.href} aria-current={isActive(item.match) ? 'page' : undefined}>
            {item.label}
          </a>
        ))}
        <button
          class="site-nav-panel-link site-nav-panel-button"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-cycle-view"
          data-mobile-cycles-open
        >
          Cycles <span aria-hidden="true">&rarr;</span>
        </button>
      </div>
      <div class="site-nav-panel-view" id="mobile-cycle-view" hidden data-mobile-cycle-view>
        <button class="site-nav-panel-link site-nav-panel-button" type="button" data-mobile-cycles-back>
          <span aria-hidden="true">&larr;</span> Back
        </button>
        {enabledCycles.map((cycle) => (
          <a class="site-nav-panel-link" href={withBase(`cycles/${cycle.id}/`)}>{cycle.name}</a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  (() => {
    const header = document.querySelector<HTMLElement>('[data-site-header]');
    const button = document.querySelector<HTMLButtonElement>('[data-mobile-menu-toggle]');
    const panel = document.querySelector<HTMLElement>('[data-mobile-menu-panel]');
    const label = document.querySelector<HTMLElement>('[data-mobile-menu-label]');
    const mainView = document.querySelector<HTMLElement>('[data-mobile-menu-main]');
    const cycleView = document.querySelector<HTMLElement>('[data-mobile-cycle-view]');
    const cycleOpen = document.querySelector<HTMLButtonElement>('[data-mobile-cycles-open]');
    const cycleBack = document.querySelector<HTMLButtonElement>('[data-mobile-cycles-back]');

    if (!header || !button || !panel || !label || !mainView || !cycleView || !cycleOpen || !cycleBack) return;

    function setCycleView(open: boolean) {
      if (!mainView || !cycleView || !cycleOpen) return;
      mainView.hidden = open;
      cycleView.hidden = !open;
      cycleOpen.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    function setOpen(open: boolean) {
      if (!header || !button || !panel || !label) return;
      header.classList.toggle('is-mobile-menu-open', open);
      button.setAttribute('aria-expanded', open ? 'true' : 'false');
      panel.hidden = !open;
      label.textContent = open ? 'Close' : 'Menu';
      setCycleView(false);
    }

    button.addEventListener('click', (event) => {
      event.stopPropagation();
      setOpen(button.getAttribute('aria-expanded') !== 'true');
    });

    cycleOpen.addEventListener('click', (event) => {
      event.stopPropagation();
      setCycleView(true);
      cycleBack.focus();
    });

    cycleBack.addEventListener('click', (event) => {
      event.stopPropagation();
      setCycleView(false);
      cycleOpen.focus();
    });

    panel.addEventListener('click', (event) => {
      event.stopPropagation();
      if (event.target instanceof Element && event.target.closest('a')) setOpen(false);
    });

    document.addEventListener('click', (event) => {
      if (!panel.hidden && !header.contains(event.target as Node)) setOpen(false);
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !panel.hidden) {
        setOpen(false);
        button.focus();
      }
    });
  })();
</script>
