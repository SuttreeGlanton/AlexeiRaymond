---
import { getImage } from 'astro:assets';
import cormundi from '../assets/codas/cormundi.png';

const heart = await getImage({ src: cormundi, width: 520, format: 'webp' });
---

<figure
  class="ns-coda"
  role="img"
  aria-label="An engraved anatomical heart beats sporadically — now racing, now slowing, now still."
>
  <span class="ns-glow ns-glow-ruby" aria-hidden="true"></span>
  <span class="ns-glow ns-glow-indigo" aria-hidden="true"></span>
  <span class="ns-beat" aria-hidden="true">
    <img src={heart.src} alt="" loading="lazy" decoding="async" width={heart.attributes.width} height={heart.attributes.height} />
  </span>
</figure>

<style>
  .ns-coda {
    position: relative;
    display: grid;
    place-items: center;
    margin: clamp(52px, 8vw, 84px) auto 0;
    text-indent: 0;
  }

  .ns-beat {
    position: relative;
    width: clamp(96px, 14vw, 126px);
    animation: nsBeat 26s linear infinite;
    transform-origin: 50% 38%;
    will-change: transform;
    filter: grayscale(1) invert(1) sepia(1) saturate(5) hue-rotate(-62deg) brightness(0.62) contrast(1.1);
    mix-blend-mode: screen;
  }

  /* The engraving arrives black-on-white; the page inverts it and lets
     Its dark, ruby flesh bleed through. Screen blend sinks the matte. */
  .ns-beat img {
    display: block;
    width: 100%;
    height: auto;
  }

  .ns-glow {
    position: absolute;
    top: 50%;
    left: 50%;
    width: clamp(190px, 28vw, 250px);
    height: clamp(190px, 28vw, 250px);
    transform: translate(-50%, -50%);
    border-radius: 50%;
    pointer-events: none;
  }

  .ns-glow-ruby {
    background: radial-gradient(circle, rgba(146, 34, 51, 0.13) 0%, rgba(146, 34, 51, 0) 62%);
    animation: nsGlowRuby 26s ease-in-out infinite;
  }

  .ns-glow-indigo {
    background: radial-gradient(circle, rgba(74, 64, 150, 0.11) 0%, rgba(74, 64, 150, 0) 62%);
    animation: nsGlowIndigo 26s ease-in-out infinite;
  }

  @keyframes nsGlowRuby {
    0%, 100% { opacity: 0.55; }
    18% { opacity: 0.95; }
    38% { opacity: 0.3; }
    55% { opacity: 0.8; }
    76% { opacity: 0.25; }
    90% { opacity: 0.6; }
  }

  @keyframes nsGlowIndigo {
    0%, 100% { opacity: 0.3; }
    18% { opacity: 0.2; }
    38% { opacity: 0.85; }
    55% { opacity: 0.3; }
    76% { opacity: 0.9; }
    90% { opacity: 0.45; }
  }

  @keyframes nsBeat {
    0% { transform: scale3d(1.0, 1.0, 1); }
    1.85% { transform: scale3d(1.0, 1.0, 1); }
    2.69% { transform: scale3d(1.05, 1.05, 1); }
    3.31% { transform: scale3d(1.0125, 1.0125, 1); }
    3.92% { transform: scale3d(1.03, 1.03, 1); }
    5.58% { transform: scale3d(1.0, 1.0, 1); }
    8.38% { transform: scale3d(1.0, 1.0, 1); }
    9.23% { transform: scale3d(1.05, 1.05, 1); }
    9.85% { transform: scale3d(1.0125, 1.0125, 1); }
    10.46% { transform: scale3d(1.03, 1.03, 1); }
    12.12% { transform: scale3d(1.0, 1.0, 1); }
    14.92% { transform: scale3d(1.0, 1.0, 1); }
    15.77% { transform: scale3d(1.048, 1.048, 1); }
    16.38% { transform: scale3d(1.012, 1.012, 1); }
    17% { transform: scale3d(1.0288, 1.0288, 1); }
    18.65% { transform: scale3d(1.0, 1.0, 1); }
    28.77% { transform: scale3d(1.0, 1.0, 1); }
    29.62% { transform: scale3d(1.075, 1.075, 1); }
    30.23% { transform: scale3d(1.0188, 1.0188, 1); }
    30.85% { transform: scale3d(1.045, 1.045, 1); }
    32.5% { transform: scale3d(1.0, 1.0, 1); }
    38.77% { transform: scale3d(1.0, 1.0, 1); }
    39.62% { transform: scale3d(1.075, 1.075, 1); }
    40.23% { transform: scale3d(1.0188, 1.0188, 1); }
    40.85% { transform: scale3d(1.045, 1.045, 1); }
    42.5% { transform: scale3d(1.0, 1.0, 1); }
    48% { transform: scale3d(1.0, 1.0, 1); }
    48.85% { transform: scale3d(1.045, 1.045, 1); }
    49.46% { transform: scale3d(1.0112, 1.0112, 1); }
    50.08% { transform: scale3d(1.027, 1.027, 1); }
    50.5% { transform: scale3d(1.0, 1.0, 1); }
    51.35% { transform: scale3d(1.046, 1.046, 1); }
    51.73% { transform: scale3d(1.0, 1.0, 1); }
    51.96% { transform: scale3d(1.0115, 1.0115, 1); }
    52.58% { transform: scale3d(1.0276, 1.0276, 1); }
    53% { transform: scale3d(1.0, 1.0, 1); }
    53.85% { transform: scale3d(1.047, 1.047, 1); }
    54.23% { transform: scale3d(1.0, 1.0, 1); }
    54.46% { transform: scale3d(1.0117, 1.0117, 1); }
    55.08% { transform: scale3d(1.0282, 1.0282, 1); }
    55.5% { transform: scale3d(1.0, 1.0, 1); }
    56.35% { transform: scale3d(1.048, 1.048, 1); }
    56.73% { transform: scale3d(1.0, 1.0, 1); }
    56.96% { transform: scale3d(1.012, 1.012, 1); }
    57.58% { transform: scale3d(1.0288, 1.0288, 1); }
    58% { transform: scale3d(1.0, 1.0, 1); }
    58.85% { transform: scale3d(1.05, 1.05, 1); }
    59.23% { transform: scale3d(1.0, 1.0, 1); }
    59.46% { transform: scale3d(1.0125, 1.0125, 1); }
    60.08% { transform: scale3d(1.03, 1.03, 1); }
    60.5% { transform: scale3d(1.0, 1.0, 1); }
    61.35% { transform: scale3d(1.052, 1.052, 1); }
    61.73% { transform: scale3d(1.0, 1.0, 1); }
    61.96% { transform: scale3d(1.013, 1.013, 1); }
    62.58% { transform: scale3d(1.0312, 1.0312, 1); }
    64.23% { transform: scale3d(1.0, 1.0, 1); }
    78% { transform: scale3d(1.0, 1.0, 1); }
    78.85% { transform: scale3d(1.09, 1.09, 1); }
    79.46% { transform: scale3d(1.0225, 1.0225, 1); }
    80.08% { transform: scale3d(1.054, 1.054, 1); }
    81.73% { transform: scale3d(1.0, 1.0, 1); }
    86.46% { transform: scale3d(1.0, 1.0, 1); }
    87.31% { transform: scale3d(1.058, 1.058, 1); }
    87.92% { transform: scale3d(1.0145, 1.0145, 1); }
    88.54% { transform: scale3d(1.0348, 1.0348, 1); }
    90.19% { transform: scale3d(1.0, 1.0, 1); }
    93% { transform: scale3d(1.0, 1.0, 1); }
    93.85% { transform: scale3d(1.05, 1.05, 1); }
    94.46% { transform: scale3d(1.0125, 1.0125, 1); }
    95.08% { transform: scale3d(1.03, 1.03, 1); }
    96.73% { transform: scale3d(1.0, 1.0, 1); }
    100% { transform: scale3d(1.0, 1.0, 1); }
  }

  @media (prefers-reduced-motion: reduce) {
    .ns-beat,
    .ns-glow-ruby,
    .ns-glow-indigo {
      animation: none;
    }
  }
</style>
