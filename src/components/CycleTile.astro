---
import OptimizedImage from './OptimizedImage.astro';
import type { Cycle } from '../lib/data';
import { assetPath, withBase } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

interface Props {
  cycle: Cycle;
}

const { cycle } = Astro.props;
const cover = cycle.cover ? assetPath(cycle.cover) : '';
const coverImage = imageAsset(cycle.cover);
const href = withBase(`cycles/${cycle.id}/`);
---

<a class="tile" href={href}>
  <div class="tile-media">
    {cover ? (
      <OptimizedImage path={cycle.cover} image={coverImage} alt={`${cycle.name} cover`} loading="lazy" sizes="(max-width: 640px) 100vw, (max-width: 1120px) 33vw, 25vw" widths={[320, 480, 640, 800, 1080, 1400]} />
    ) : (
      <div class="placeholder" aria-hidden="true"><span>{cycle.name}</span></div>
    )}
    {cycle.blurb && (
      <div class="tile-overlay" aria-hidden="true">
        <p class="tile-blurb">{cycle.blurb}</p>
      </div>
    )}
  </div>
  <div class="tile-body">
    <h3 class="tile-title">{cycle.name}</h3>
    {cycle.blurb && <p class="tile-mobile-blurb">{cycle.blurb}</p>}
  </div>
</a>
