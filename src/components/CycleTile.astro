---
import OptimizedImage from './OptimizedImage.astro';
import { cycleTeaser, type Cycle } from '../lib/data';
import { assetPath, withBase } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

interface Props {
  cycle: Cycle;
}

const { cycle } = Astro.props;
const teaser = cycleTeaser(cycle);
const cover = cycle.cover ? assetPath(cycle.cover) : '';
const coverImage = imageAsset(cycle.cover);
const disabled = Boolean(cycle.disabled);
const href = disabled ? '' : withBase(`cycles/${cycle.id}/`);
const cycleCoverWidths = [240, 400, 480, 520, 560, 600, 640, 760];
// Mobile covers are intentionally capped near 1.5x their rendered width. The
// extra density is visually redundant here and previously made Lighthouse
// choose a 760px source for a roughly 583px rendered image.
const cycleCoverSizes = '(max-width: 640px) 82vw, (max-width: 1120px) 33vw, 295px';
---

{
  disabled ? (
    <div class="tile tile--disabled" data-cycle-id={cycle.id} aria-disabled="true">
      <div class="tile-media">
        {cover ? (
          <OptimizedImage
            path={cycle.cover}
            image={coverImage}
            alt={`${cycle.name} cover`}
            loading="lazy"
            sizes={cycleCoverSizes}
            widths={cycleCoverWidths}
            quality={72}
          />
        ) : (
          <div class="placeholder" aria-hidden="true"><span>{cycle.name}</span></div>
        )}
        {teaser && (
          <div class="tile-overlay" aria-hidden="true">
            <p class="tile-blurb">{teaser}</p>
          </div>
        )}
      </div>
      <div class="tile-body">
        <h3 class="tile-title">{cycle.name}</h3>
        {teaser && <p class="tile-mobile-blurb">{teaser}</p>}
      </div>
    </div>
  ) : (
    <a class="tile" data-cycle-id={cycle.id} href={href}>
      <div class="tile-media">
        {cover ? (
          <OptimizedImage
            path={cycle.cover}
            image={coverImage}
            alt={`${cycle.name} cover`}
            loading="lazy"
            sizes={cycleCoverSizes}
            widths={cycleCoverWidths}
            quality={72}
          />
        ) : (
          <div class="placeholder" aria-hidden="true"><span>{cycle.name}</span></div>
        )}
        {teaser && (
          <div class="tile-overlay" aria-hidden="true">
            <p class="tile-blurb">{teaser}</p>
          </div>
        )}
      </div>
      <div class="tile-body">
        <h3 class="tile-title">{cycle.name}</h3>
        {teaser && <p class="tile-mobile-blurb">{teaser}</p>}
      </div>
    </a>
  )
}
