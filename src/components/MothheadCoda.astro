---
/* Mothhead coda: behavior only — wraps every whole-word "moth"/"moths" and the
   Italian "falene" in the story as a quiet button. A click releases moths; the
   final instance bursts a small swarm on each click and streams a continuous
   flutter while held down.
   The live-moth cap keeps either from ever overwhelming the page. */
---

<!-- mothhead coda (behavior only) -->

<script>
  const MH_SPRITES = [
    "data:image/png;base64,",
    "data:image/png;base64,"
  ];

  const mhReduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  const mhProse = document.querySelector('.archive-prose');

  if (mhProse) {
    /* ---- wrap whole-word moth/moths/falene instances ---- */
    const mhWords: HTMLButtonElement[] = [];
    const mhWalker = document.createTreeWalker(mhProse, NodeFilter.SHOW_TEXT, {
      acceptNode(node) {
        if (!node.nodeValue || !/\b(?:moths?|falene)\b/i.test(node.nodeValue)) return NodeFilter.FILTER_REJECT;
        const parent = (node as Text).parentElement;
        if (!parent || parent.closest('button, a, script, style, .mh-skip')) return NodeFilter.FILTER_REJECT;
        return NodeFilter.FILTER_ACCEPT;
      }
    });

    const mhTextNodes: Text[] = [];
    while (mhWalker.nextNode()) mhTextNodes.push(mhWalker.currentNode as Text);

    for (const node of mhTextNodes) {
      const text = node.nodeValue ?? '';
      const frag = document.createDocumentFragment();
      const re = /\b(?:moths?|falene)\b/gi;
      let last = 0;
      let m: RegExpExecArray | null;
      while ((m = re.exec(text)) !== null) {
        frag.append(document.createTextNode(text.slice(last, m.index)));
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'mh-word';
        btn.textContent = m[0];
        btn.setAttribute('aria-label', `${m[0]} — release a moth`);
        frag.append(btn);
        mhWords.push(btn);
        last = m.index + m[0].length;
      }
      frag.append(document.createTextNode(text.slice(last)));
      node.parentNode?.replaceChild(frag, node);
    }

    const mhFinal = mhWords.length > 0 ? mhWords[mhWords.length - 1] : null;
    mhFinal?.classList.add('mh-word--final');

    /* ---- flight ---- */
    let mhVariant = 0;
    let mhLive = 0;
    let mhSuppressClick = false;
    const MH_MAX_LIVE = 12;

    const mhRest = (word: HTMLButtonElement, ms: number) => {
      word.classList.add('is-resting');
      window.setTimeout(() => word.classList.remove('is-resting'), ms);
    };

    const spawnMothFrom = (rect: DOMRect) => {
      if (mhLive >= MH_MAX_LIVE) return;
      mhLive++;

      const sprite = MH_SPRITES[mhVariant++ % MH_SPRITES.length];
      const x0 = rect.left + rect.width / 2;
      const y0 = rect.top + rect.height / 2;

      const fly = document.createElement('span');
      fly.className = 'mh-moth-fly';
      fly.setAttribute('aria-hidden', 'true');
      const img = document.createElement('img');
      img.src = sprite;
      img.alt = '';
      fly.append(img);
      document.body.append(fly);

      const done = () => {
        fly.remove();
        mhLive--;
      };

      if (mhReduceMotion) {
        /* no flight: appear at the word, fade where it sits */
        fly.style.transform = `translate(${x0}px, ${y0}px) translate(-50%, -50%)`;
        fly.animate(
          [{ opacity: 0 }, { opacity: 1, offset: 0.25 }, { opacity: 1, offset: 0.55 }, { opacity: 0 }],
          { duration: 1400, easing: 'ease-in-out', fill: 'forwards' }
        ).finished.then(done, done);
        return;
      }

      const angle = Math.random() * Math.PI * 2;
      const travel = (0.3 + Math.random() * 0.2) * Math.min(window.innerWidth, window.innerHeight);
      const wobbles = 2 + Math.random() * 2;
      const amp = 12 + Math.random() * 20;
      const size = 0.85 + Math.random() * 0.3;
      const baseRot = (angle * 180) / Math.PI + 90;
      const dur = 2400 + Math.random() * 1600;
      const N = 26;
      const frames: Keyframe[] = [];
      for (let i = 0; i <= N; i++) {
        const t = i / N;
        const along = travel * t;
        const side = Math.sin(t * Math.PI * wobbles) * amp * (1 - t * 0.35);
        const dx = Math.cos(angle) * along + Math.cos(angle + Math.PI / 2) * side;
        const dy = Math.sin(angle) * along + Math.sin(angle + Math.PI / 2) * side;
        const pop = t < 0.08 ? 0.35 + (t / 0.08) * 0.65 : 1;
        const bank = Math.cos(t * Math.PI * wobbles) * 14 * (1 - t * 0.4);
        frames.push({
          transform: `translate(${x0 + dx}px, ${y0 + dy}px) translate(-50%, -50%) rotate(${baseRot + bank}deg) scale(${size * pop})`,
          opacity: t < 0.05 ? t / 0.05 : t > 0.78 ? Math.max(0, 1 - (t - 0.78) / 0.22) : 1
        });
      }

      img.animate(
        [{ transform: 'scaleX(1)' }, { transform: 'scaleX(0.5)' }],
        { duration: 150, iterations: Infinity, direction: 'alternate', easing: 'ease-in-out' }
      );
      fly.animate(frames, { duration: dur, easing: 'linear', fill: 'forwards' }).finished.then(done, done);
    };

    for (const word of mhWords) {
      word.addEventListener('click', () => {
        /* A hold just ended: swallow the trailing click so it doesn't
           also fire a burst. */
        if (word === mhFinal && mhSuppressClick) {
          mhSuppressClick = false;
          return;
        }
        if (word.classList.contains('is-resting')) return;
        if (word === mhFinal) {
          /* The final word bursts a swarm every time, on a short cooldown. */
          for (let k = 0; k < 8; k++) {
            window.setTimeout(() => spawnMothFrom(word.getBoundingClientRect()), k * 70);
          }
          mhRest(word, 3000);
        } else {
          spawnMothFrom(word.getBoundingClientRect());
          mhRest(word, 8000);
        }
      });
    }

    /* ---- press-and-hold the final word for a continuous release ---- */
    if (mhFinal) {
      const MH_HOLD_MS = 240;   /* press longer than this becomes a hold */
      const MH_EMIT_MS = 130;   /* one moth per this while held (cap still applies) */
      let holdTimer = 0;
      let emitTimer = 0;

      const emitOne = () => spawnMothFrom(mhFinal.getBoundingClientRect());

      const stopHold = () => {
        window.clearTimeout(holdTimer);
        holdTimer = 0;
        if (emitTimer) {
          window.clearInterval(emitTimer);
          emitTimer = 0;
        }
      };

      mhFinal.addEventListener('pointerdown', (event) => {
        if (event.button !== 0 && event.pointerType === 'mouse') return;
        mhSuppressClick = false;
        window.clearTimeout(holdTimer);
        holdTimer = window.setTimeout(() => {
          /* Cross into hold mode: the ensuing click is a hold-release, not a tap. */
          mhSuppressClick = true;
          mhFinal.classList.remove('is-resting');
          mhFinal.classList.add('is-holding');
          emitOne();
          emitTimer = window.setInterval(emitOne, MH_EMIT_MS);
        }, MH_HOLD_MS);
      });

      const endPress = () => {
        stopHold();
        mhFinal.classList.remove('is-holding');
      };
      mhFinal.addEventListener('pointerup', endPress);
      mhFinal.addEventListener('pointercancel', endPress);
      mhFinal.addEventListener('pointerleave', endPress);
      window.addEventListener('blur', endPress);

      /* Don't let a long press raise the mobile callout / context menu. */
      mhFinal.addEventListener('contextmenu', (event) => {
        if (emitTimer) event.preventDefault();
      });
    }
  }
</script>

<style is:global>
  .mh-word {
    appearance: none;
    -webkit-appearance: none;
    font: inherit;
    color: inherit;
    letter-spacing: inherit;
    background: none;
    border: 0;
    margin: 0;
    padding: 0;
    cursor: pointer;
    border-radius: 2px;
    transition: text-shadow 320ms ease;
    -webkit-tap-highlight-color: transparent;
  }

  .mh-word:hover:not(.is-resting),
  .mh-word:focus-visible:not(.is-resting) {
    text-shadow:
      0 0 9px rgba(236, 214, 176, 0.6),
      0 0 2px rgba(236, 214, 176, 0.45);
  }

  .mh-word:focus-visible {
    outline: 1px solid var(--border-strong);
    outline-offset: 2px;
  }

  .mh-word.is-resting {
    cursor: default;
  }

  /* The last moth in the story sits by the lamp. */
  .mh-word--final {
    animation: mh-lamp 4.2s ease-in-out infinite;
    -webkit-user-select: none;
    user-select: none;
    -webkit-touch-callout: none;
    touch-action: manipulation;
  }

  /* Held down: the lamp holds steady and bright while moths keep coming. */
  .mh-word--final.is-holding {
    animation: none;
    text-shadow:
      0 0 3px rgba(240, 220, 180, 0.95),
      0 0 12px rgba(236, 214, 176, 0.65),
      0 0 28px rgba(236, 214, 176, 0.4);
  }

  @keyframes mh-lamp {
    0%, 100% {
      filter: brightness(1);
      text-shadow:
        0 0 2px rgba(236, 214, 176, 0.14),
        0 0 6px rgba(236, 214, 176, 0.06);
    }

    12% {
      filter: brightness(1.22);
      text-shadow:
        0 0 3px rgba(240, 220, 180, 0.9),
        0 0 12px rgba(236, 214, 176, 0.6),
        0 0 28px rgba(236, 214, 176, 0.35);
    }

    26% {
      filter: brightness(1);
      text-shadow:
        0 0 2px rgba(236, 214, 176, 0.16),
        0 0 7px rgba(236, 214, 176, 0.07);
    }
  }

  .mh-moth-fly {
    position: fixed;
    left: 0;
    top: 0;
    z-index: 45;
    pointer-events: none;
  }

  .mh-moth-fly img {
    display: block;
    width: clamp(24px, 3vw, 30px);
    height: auto;
  }

  @media (prefers-reduced-motion: reduce) {
    .mh-word {
      transition: none;
    }

    .mh-word--final {
      animation: none;
    }
  }
</style>
