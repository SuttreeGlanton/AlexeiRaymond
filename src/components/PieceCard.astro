---
import TagList from './TagList.astro';
import OptimizedImage from './OptimizedImage.astro';
import type { Piece } from '../lib/data';
import { canLinkToPiece, formatShortDate, isDefunct, isUpcoming, parseDate, publicationLabel } from '../lib/data';
import { assetPath, withBase } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

interface Props {
  piece: Piece;
  showCycle?: boolean;
  storyOrder?: number;
  sourceOrder?: number;
  priority?: boolean;
  imageSizes?: string;
  imageWidths?: number[];
}

const {
  piece,
  showCycle = false,
  storyOrder,
  sourceOrder,
  priority = false,
  imageSizes = '(max-width: 640px) 85vw, (max-width: 860px) 45vw, 360px',
  imageWidths = [240, 400, 560, 640, 760]
} = Astro.props;
const upcoming = isUpcoming(piece);
const defunct = isDefunct(piece);
const linked = canLinkToPiece(piece);
const cover = piece.cover ? assetPath(piece.cover) : '';
const coverImage = imageAsset(piece.cover);
const accountHref = piece.account ? withBase(`accounts/${piece.account.slug}/`) : '';
const accountLabel = piece.account?.label || 'Account';
const longTitle = piece.title.length >= 18;
const cycleTitleFit = piece.title === '193 Thoughts of You';
const className = `piece-card${upcoming ? ' is-upcoming' : ''}${defunct ? ' is-defunct' : ''}${longTitle ? ' has-long-title' : ''}${cycleTitleFit ? ' has-cycle-title-fit' : ''}`;

const cycleLabel = showCycle ? `From the ${piece.cycle} cycle` : '';
// Render the date as a compact cover plate to prevent metadata wrapping.
const dateLabel = upcoming ? '' : formatShortDate(piece.date);
const publicationTime = parseDate(piece.date)?.getTime() ?? 0;
const storyOrderLabel = storyOrder ? String(storyOrder).padStart(2, '0') : '';

// Use shortened genre labels for the compact cover plate.
const GENRE_SHORT: Record<string, string> = {
  'Short fiction': 'Short fiction',
  'Flash fiction': 'Flash',
  'Poem': 'Poem',
  'Non-fiction': 'Non-fiction',
  'Other': 'Other'
};
const genreLabel = piece.genre ? (GENRE_SHORT[piece.genre] ?? piece.genre) : '';
const genreSlug = piece.genre ? piece.genre.toLowerCase().replace(/[^a-z]+/g, '-') : '';
const imageLoading = priority ? 'eager' : 'lazy';
const imageFetchPriority = priority ? 'high' : undefined;
const coverLinkLabel = [
  genreLabel,
  dateLabel,
  `Read ${piece.title} at ${publicationLabel(piece)}.`,
  'Opens in a new tab.'
].filter(Boolean).join(' ');
const metaParts = [
  cycleLabel ? { text: cycleLabel } : null,
  piece.publication ? { text: publicationLabel(piece), className: 'card-publication' } : null
].filter(Boolean);
---

<article
  class={className}
  data-piece-card
  data-story-order={storyOrder}
  data-source-order={sourceOrder}
  data-publication-time={publicationTime}
  data-upcoming={upcoming ? 'true' : 'false'}
>
  {linked ? (
    <a class="card-cover-link" href={piece.link} target="_blank" rel="noopener noreferrer" tabindex="-1" aria-label={coverLinkLabel}>
      <div class="card-media">
        {cover ? (
          <OptimizedImage path={piece.cover} image={coverImage} alt={`${piece.title} cover`} loading={imageLoading} fetchpriority={imageFetchPriority} sizes={imageSizes} widths={imageWidths} />
        ) : (
          <div class="placeholder" aria-hidden="true"><span>{piece.title}</span></div>
        )}
        {genreLabel && <span class="genre-mark" data-genre={genreSlug}>{genreLabel}</span>}
        {dateLabel && <span class="date-mark">{dateLabel}</span>}
        {piece.excerpt && (
          <div class="card-overlay" aria-hidden="true">
            <p class="card-excerpt">&ldquo;{piece.excerpt}&rdquo;</p>
          </div>
        )}
      </div>
    </a>
  ) : (
    <div class="card-media">
      {cover ? (
        <OptimizedImage path={piece.cover} image={coverImage} alt={`${piece.title} cover`} loading={imageLoading} fetchpriority={imageFetchPriority} sizes={imageSizes} widths={imageWidths} />
      ) : (
        <div class="placeholder" aria-hidden="true"><span>{piece.title}</span></div>
      )}
      {genreLabel && <span class="genre-mark" data-genre={genreSlug}>{genreLabel}</span>}
      {dateLabel && <span class="date-mark">{dateLabel}</span>}
      {piece.excerpt && (
        <div class="card-overlay" aria-hidden="true">
          <p class="card-excerpt">&ldquo;{piece.excerpt}&rdquo;</p>
        </div>
      )}
    </div>
  )}
  <div class="card-body">
    {storyOrderLabel && <span class="story-order-mark">Story {storyOrderLabel}</span>}
    <h2 class="card-title">
      {linked ? (
        <a href={piece.link} target="_blank" rel="noopener noreferrer" aria-label={`Read ${piece.title} at ${publicationLabel(piece)}. Opens in a new tab.`}>{piece.title}</a>
      ) : (
        piece.title
      )}
    </h2>
    {metaParts.length > 0 && (
      <div class="card-meta">
        {metaParts.map((part, index) => (
          <>
            {index > 0 && <span class="meta-separator" aria-hidden="true">&middot;</span>}
            <span class={part.className}>{part.text}</span>
          </>
        ))}
      </div>
    )}
    {upcoming && <p class="coming-soon">Coming soon</p>}
    {piece.excerpt && <p class="card-mobile-excerpt">&ldquo;{piece.excerpt}&rdquo;</p>}
    {piece.note && <p class="card-note">{piece.note}</p>}
    <TagList tags={piece.tags} />
  </div>
  {piece.account && (
    <a class="account-strip" href={accountHref} aria-label={`${accountLabel}: ${piece.title} on this site`}>{accountLabel} &rarr;</a>
  )}
</article>
