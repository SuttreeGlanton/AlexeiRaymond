    aspect-ratio: 3 / 2;
    overflow: hidden;
    border: 7px solid #14161a;
    box-shadow:
      inset 0 0 0 1px rgba(226, 238, 244, 0.07),
      inset 0 0 46px rgba(0, 0, 0, 0.5),
