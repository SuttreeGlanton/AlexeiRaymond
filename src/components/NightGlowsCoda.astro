--ix, 50%) + 53px) calc(var(--iy, 45%) - 9px), calc(var(--ix, 50%) + 48px) calc(var(--iy, 45%) - 9px));
  }

  [data-state='cracked'] .ng-shard--f1,
  [data-state='cracked'] .ng-shard--f2,
  [data-state='cracked'] .ng-shard--f3 {
    animation: ng-fall 1.15s ease-in forwards;
  }

  [data-state='smashed'] .ng-window {
    animation: ng-thud-big 340ms ease;
  }

  [data-state='smashed'] .ng-cracks--1,
  [data-state='smashed'] .ng-cracks--2 {
    opacity: 0;
    transition-delay: 160ms;
  }

  [data-state='smashed'] .ng-sheen {
    opacity: 0;
  }

  [data-state='smashed'] .ng-rim {
    opacity: 1;
  }

  /* The glass is gone; the city blooms. */
  [data-state='smashed'] .ng-city {
    filter: grayscale(0);
  }

  [data-state='smashed'] .ng-shard--b1,
  [data-state='smashed'] .ng-shard--b2,
  [data-state='smashed'] .ng-shard--b3,
  [data-state='smashed'] .ng-shard--b4,
  [data-state='smashed'] .ng-shard--b5,
  [data-state='smashed'] .ng-shard--b6 {
    animation: ng-burst 950ms cubic-bezier(0.16, 0.6, 0.35, 1) forwards;
  }

  @keyframes ng-thud {
    0% { transform: translate(0, 0); }
    30% { transform: translate(-2px, 1px); }
    60% { transform: translate(1.5px, -1px); }
    100% { transform: translate(0, 0); }
  }

  @keyframes ng-thud-big {
    0% { transform: translate(0, 0); }
    25% { transform: translate(-3px, 2px); }
    55% { transform: translate(2.5px, -1.5px); }
    80% { transform: translate(-1px, 1px); }
    100% { transform: translate(0, 0); }
  }

  @keyframes ng-fall {
    0% { opacity: 0.95; transform: translate(0, 0) rotate(0deg); }
    75% { opacity: 0.8; }
    100% { opacity: 0; transform: translate(var(--fx, 0), var(--fy, 120px)) rotate(var(--fr, 160deg)); }
  }

  @keyframes ng-burst {
    0% { opacity: 0.95; transform: translate(0, 0) rotate(0deg) scale(1); }
    70% { opacity: 0.7; }
    100% { opacity: 0; transform: translate(var(--bx, 0), var(--by, 0)) rotate(var(--br, 200deg)) scale(0.7); }
  }

  @media (max-width: 640px) {
