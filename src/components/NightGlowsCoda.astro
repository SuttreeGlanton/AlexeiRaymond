    background:
      linear-gradient(115deg, rgba(208, 224, 234, 0.15) 0%, rgba(208, 224, 234, 0.02) 28%, transparent 45%, rgba(208, 224, 234, 0.05) 72%, rgba(208, 224, 234, 0.13) 100%),
