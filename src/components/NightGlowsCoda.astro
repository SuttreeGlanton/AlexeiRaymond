    transition: opacity 700ms ease;
    pointer-events: none;
  }

  .ng-city-clear {
    opacity: 0;
    pointer-events: none;
  }

  /* Cracks radiate from the point of impact; the svg is a 200x200 pixel
     grid stretched over an 800px field, so one unit reads as one pixel. */
  .ng-cracks {
    position: absolute;
    left: var(--ix, 50%);
    top: var(--iy, 45%);
    width: 800px;
    height: 800px;
    transform: translate(-50%, -50%);
