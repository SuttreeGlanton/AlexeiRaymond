<script>
  const ngCoda = document.querySelector<HTMLElement>('[data-night-glows]');

  if (ngCoda) {
    const ngHit = ngCoda.querySelector<HTMLButtonElement>('[data-ng-hit]');
    const ngWindow = ngCoda.querySelector<HTMLElement>('.ng-window');
    const ngStates = ['intact', 'marked', 'cracked', 'smashed'];
    const ngLabels: Record<string, string> = {
      intact: 'Strike the window',
      marked: 'Strike the window again',
      cracked: 'Strike the window a third time',
      smashed: 'The window is broken'
    };

    ngHit?.addEventListener('click', (event) => {
      const current = ngCoda.getAttribute('data-state') || 'intact';
      const next = ngStates[Math.min(ngStates.indexOf(current) + 1, ngStates.length - 1)];
      if (next === current) return;

      /* The first strike sets the point of impact; everything that follows
         radiates from it. Keyboard activation lands center-pane. */
      if (!ngCoda.hasAttribute('data-ng-armed') && ngWindow) {
        const rect = ngWindow.getBoundingClientRect();
        const x = event.clientX > 0 ? event.clientX - rect.left : rect.width * 0.5;
        const y = event.clientY > 0 ? event.clientY - rect.top : rect.height * 0.45;
        ngCoda.style.setProperty('--ix', `${Math.round(x)}px`);
        ngCoda.style.setProperty('--iy', `${Math.round(y)}px`);
        ngCoda.setAttribute('data-ng-armed', '');
      }

      ngCoda.setAttribute('data-state', next);
      ngHit.setAttribute('aria-label', ngLabels[next]);

      if (next === 'smashed') {
        ngHit.disabled = true;

        /* The city keeps sounding after the glass is gone. The strike that
           triggers this is a user gesture, so playback is permitted; if the
           file is absent or autoplay is refused, fail silent. */
        const ngAmbient = ngCoda.querySelector<HTMLAudioElement>('[data-ng-ambient]');
        if (ngAmbient) {
          ngAmbient.volume = 0;
          const ngFade = window.setInterval(() => {
            ngAmbient.volume = Math.min(0.55, ngAmbient.volume + 0.05);
            if (ngAmbient.volume >= 0.55) window.clearInterval(ngFade);
          }, 160);
          ngAmbient.play().catch(() => window.clearInterval(ngFade));
        }
      }
    });
  }
</script>

<style>
  .night-glows-coda {
    width: min(720px, 100%);
    margin: clamp(3.5rem, 9vw, 6rem) auto 0;
