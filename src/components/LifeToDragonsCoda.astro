<script>
  const lizardCodas = document.querySelectorAll<HTMLElement>('[data-ltd-coda]');

  for (const coda of lizardCodas) {
    const lizard = coda.querySelector('[data-ltd-lizard]');
    const status = coda.querySelector('[data-ltd-status]');
    if (!(lizard instanceof HTMLButtonElement)) continue;

    // Three patches of shaded, soft earth.
    const spots = [6, 44, 82];
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let at = 1;
    let running = false;

    lizard.style.left = `${spots[at]}%`;

    const dart = (target: number) => {
      if (running) return;

      const facing = spots[target] > spots[at] ? '1' : '-1';
      lizard.style.setProperty('--ltd-face', facing);
      at = target;
      running = true;
      lizard.classList.add('is-running');
      lizard.style.left = `${spots[at]}%`;

      window.setTimeout(() => {
        lizard.classList.remove('is-running');
        running = false;
      }, reducedMotion ? 30 : 500);
    };

    const flee = (event?: Event) => {
      if (running) return;

      const others = [0, 1, 2].filter((index) => index !== at);
      let target = others[Math.floor(Math.random() * others.length)];

      // Run from the reaching hand: pick the spot farthest from the pointer.
      if (event instanceof PointerEvent && Number.isFinite(event.clientX)) {
        const rect = coda.getBoundingClientRect();
        const pointer = ((event.clientX - rect.left) / rect.width) * 100;
        target = others.reduce((a, b) =>
          Math.abs(spots[a] - pointer) >= Math.abs(spots[b] - pointer) ? a : b
        );
      }

      dart(target);
      if (status instanceof HTMLElement) status.textContent = 'The lizard rustles away.';
    };

    // A life of its own: now and then it rustles off unprompted.
    const wander = () => {
      window.setTimeout(() => {
        if (!reducedMotion && !running && !document.hidden) {
          const others = [0, 1, 2].filter((index) => index !== at);
          dart(others[Math.floor(Math.random() * others.length)]);
        }
        wander();
      }, 6000 + Math.random() * 9000);
    };
    wander();

    lizard.addEventListener('pointerenter', flee);
    lizard.addEventListener('click', flee);
    lizard.addEventListener('focus', () => flee());
  }
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    margin: -1px;
    padding: 0;
    border: 0;
    overflow: hidden;
    clip: rect(0 0 0 0);
    clip-path: inset(50%);
    white-space: nowrap;
  }

  .ltd-coda {
    position: relative;
    height: 136px;
    margin: clamp(4rem, 10vw, 7rem) 0 0;
    text-indent: 0;
  }

  /* slightly grassy ground */
  .ltd-grass {
    position: absolute;
    right: 0;
    bottom: 6px;
    left: 0;
    height: 28px;
    background: url('data:image/png;base64,') repeat-x bottom / 128px 28px;
    image-rendering: pixelated;
    pointer-events: none;
  }

  .ltd-lizard {
    position: absolute;
    bottom: 9px;
    left: 44%;
    width: 142px;
    padding: 4px 2px 0;
    border: 0;
    background: transparent;
    cursor: pointer;
    touch-action: manipulation;
    transition: left 0.46s cubic-bezier(0.24, 0.85, 0.32, 1);
  }

  .ltd-lizard:focus-visible {
    outline: 1px solid var(--dim);
    outline-offset: 6px;
  }

  .ltd-lizard svg {
    display: block;
    width: 100%;
    height: auto;
    transform: scaleX(var(--ltd-face, 1));
  }

  /* Some soft, feeble expansion against his thumb: the lizard breathes. */
  .ltd-inner {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    animation: ltdBreathe 3s ease-in-out infinite;
  }

  .ltd-legs-runa,
  .ltd-legs-runb {
    opacity: 0;
  }

  .is-running .ltd-inner {
    animation: none;
  }

  .is-running .ltd-legs-rest {
    opacity: 0;
  }

  .is-running .ltd-legs-runa {
    animation: ltdGaitA 0.16s steps(1, end) infinite;
  }

  .is-running .ltd-legs-runb {
    animation: ltdGaitB 0.16s steps(1, end) infinite;
  }

  @keyframes ltdBreathe {
    0%, 100% { transform: scaleY(1); }
    50% { transform: scaleY(1.035); }
  }

  @keyframes ltdGaitA {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  @keyframes ltdGaitB {
    0%, 100% { opacity: 0; }
    50% { opacity: 1; }
  }

  @media (max-width: 640px) {
    .ltd-coda { height: 112px; }
    .ltd-lizard { width: 108px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .ltd-lizard {
      transition: none;
    }

    .ltd-inner,
    .is-running .ltd-legs-runa,
    .is-running .ltd-legs-runb {
      animation: none;
    }

    .is-running .ltd-legs-rest {
      opacity: 1;
    }

    .is-running .ltd-legs-runa,
    .is-running .ltd-legs-runb {
      opacity: 0;
    }
  }
</style>
