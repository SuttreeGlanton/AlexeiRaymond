---
// One quiet line-icon per cycle, drawn to match the site's hairline weight.
// Rendered beside the cycle title; sized in em so it scales with the type.
interface Props {
  id: string;
}

const { id } = Astro.props;
---

<span class="cycle-icon" aria-hidden="true">
  {id === 'mythbreaking' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M8.5 8.5h18" />
      <path d="M13 8.5v6.5" />
      <path d="M17.5 8.5v5" />
      <path d="M22 8.5v6" />
      <path d="M11.5 18v7.5" />
      <path d="M16 18.5v7" />
      <path d="M20.5 18v7.5" />
      <path d="M9 25.5h14" />
      <path d="M6 28.5h20" />
    </svg>
  )}

  {id === 'mythmaking' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <path d="M7 6.5h18M9 25.5h14M11.5 9v14M16 9v14M20.5 9v14M6 28.5h20" />
    </svg>
  )}
  {id === 'fools-gold' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
      <path d="M16 4 28 16 16 28 4 16Z" />
      <path d="M16 4v24M4 16h24" />
      <circle cx="16" cy="16" r="2" fill="currentColor" stroke="none" />
    </svg>
  )}
  {id === 'dreams' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5">
      <circle cx="12.5" cy="24.5" r="2.2" />
      <circle cx="18.5" cy="16.5" r="3.2" />
      <circle cx="13.5" cy="7.5" r="4.5" />
    </svg>
  )}
  {id === 'portici' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round">
      <path d="M16 1.5v4" />
      <path d="M13.9 12 16 5.5 18.1 12" />
      <path d="M13.9 12h4.2" />
      <path d="M13.9 12c-.5 3.2-2.3 5.2-4.4 6.3M18.1 12c.5 3.2 2.3 5.2 4.4 6.3" />
      <path d="M9.5 18.3h13" />
      <path d="M10.5 18.3v8.2M21.5 18.3v8.2" />
      <path d="M13 22.5h6" />
      <path d="M6.5 26.5h19" />
    </svg>
  )}
  {id === 'valentines-star' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round">
      <path d="M16 3.5c1.3 8.2 2.6 9.7 10.5 12.5-7.9 2.8-9.2 4.3-10.5 12.5-1.3-8.2-2.6-9.7-10.5-12.5 7.9-2.8 9.2-4.3 10.5-12.5Z" />
    </svg>
  )}
  {id === 'the-real' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 8.5 16 4.6 20 8.5" />
      <path d="M12.8 8.5V12h6.4V8.5" />
      <path d="M11 12h10" />
      <path d="M12 12 9.8 25" />
      <path d="M20 12 22.2 25" />
      <path d="M9.8 25h12.4" />
      <path d="M13.3 18.4h5.4" />
      <path d="M11.4 9.2 8.4 7.8" />
      <path d="M11 11h-3" />
      <path d="M20.6 9.2 23.6 7.8" />
      <path d="M21 11h3" />
      <path d="M8 27c1.3-1 2.6-1 3.9 0s2.6 1 3.9 0 2.6-1 3.9 0 2.6 1 3.9 0" />
      <path d="M8 29c1.3-1 2.6-1 3.9 0s2.6 1 3.9 0 2.6-1 3.9 0 2.6 1 3.9 0" />
    </svg>
  )}

  {id === 'conscription' && (
    <svg viewBox="0 0 32 32" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M11 5.5c1.6 2.4 8.4 2.4 10 0" />
      <path d="M13.2 6.6 12 10.4" />
      <path d="M18.8 6.6 20 11" />
      <rect x="8" y="10.2" width="6.2" height="11.4" rx="2" transform="rotate(-10 11.1 15.9)" />
      <rect x="17.8" y="11.2" width="6.2" height="11.4" rx="2" transform="rotate(9 20.9 16.9)" />
    </svg>
  )}

</span>

<style>
  .cycle-icon {
    display: inline-block;
    width: 0.52em;
    height: 0.52em;
    margin-right: 0.16em;
    color: currentColor;
    vertical-align: 0.03em;
  }

  .cycle-icon svg {
    display: block;
    width: 100%;
    height: 100%;
  }
</style>
