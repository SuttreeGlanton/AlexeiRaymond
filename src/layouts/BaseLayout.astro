---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource/sorts-mill-goudy';
import '@fontsource/sorts-mill-goudy/400-italic.css';
import '@fontsource/eb-garamond/400.css';
import '@fontsource/eb-garamond/400-italic.css';
import { site, socialHref } from '../lib/data';
import { absoluteSiteUrl, withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
  robots?: string;
  canonicalPath?: string;
  socialImage?: { src: string; width?: number; height?: number };
  socialImageAlt?: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  structuredData?: Record<string, unknown>;
  preloadAudio?: string;
}

const {
  title = site.author,
  description = site.bio,
  robots,
  canonicalPath,
  socialImage: pageSocialImage,
  socialImageAlt,
  ogType = 'website',
  publishedTime,
  structuredData,
  preloadAudio
} = Astro.props;
const canonical = absoluteSiteUrl(canonicalPath ?? Astro.url.pathname, Astro.site);
const socialImageSource = pageSocialImage?.src || site.socialCard || '';
const socialImage = socialImageSource ? absoluteSiteUrl(socialImageSource, Astro.site) : '';
const socialImageWidth = pageSocialImage?.width ?? (site.socialCard ? 1200 : undefined);
const socialImageHeight = pageSocialImage?.height ?? (site.socialCard ? 630 : undefined);
const resolvedSocialImageAlt = socialImageAlt || `${site.author} author site`;
const twitterCard = socialImage ? 'summary_large_image' : 'summary';
const siteUrl = absoluteSiteUrl('', Astro.site);
const sameAs = site.socials.map(socialHref).filter(Boolean);
const serializeJsonLd = (value: Record<string, unknown>) =>
  JSON.stringify(value).replace(/</g, '\\u003c');
const personSchema = serializeJsonLd({
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${siteUrl}#person`,
  name: site.author,
  url: siteUrl,
  sameAs
});
const pageSchema = structuredData ? serializeJsonLd(structuredData) : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href={withBase('sitemap-index.xml')} />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('apple-touch-icon.png')} />
    {preloadAudio && <link rel="preload" as="audio" href={preloadAudio} type="audio/mpeg" />}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.author} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogType === 'article' && <meta property="article:author" content={siteUrl} />}
    {ogType === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && (
      <>
        <meta property="og:image" content={socialImage} />
        {socialImageWidth && <meta property="og:image:width" content={String(socialImageWidth)} />}
        {socialImageHeight && <meta property="og:image:height" content={String(socialImageHeight)} />}
        <meta property="og:image:alt" content={resolvedSocialImageAlt} />
        <meta name="twitter:image" content={socialImage} />
        <meta name="twitter:image:alt" content={resolvedSocialImageAlt} />
      </>
    )}
    <script is:inline type="application/ld+json" set:html={personSchema}></script>
    {pageSchema && <script is:inline type="application/ld+json" set:html={pageSchema}></script>}
    <title>{title}</title>
  </head>
  <body>
    <SiteHeader />
    <main class="site-main">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
