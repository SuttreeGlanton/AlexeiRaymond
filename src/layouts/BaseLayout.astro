---
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource/sorts-mill-goudy';
import '@fontsource/sorts-mill-goudy/400-italic.css';
import '@fontsource/eb-garamond/400.css';
import '@fontsource/eb-garamond/400-italic.css';
import { site, socialHref } from '../lib/data';
import { withBase } from '../lib/paths';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = site.author,
  description = site.bio
} = Astro.props;
const canonical = new URL(withBase(Astro.url.pathname.replace(import.meta.env.BASE_URL, '')), Astro.site).toString();
const socialImage = site.socialCard ? new URL(withBase(site.socialCard), Astro.site).toString() : '';
const twitterCard = socialImage ? 'summary_large_image' : 'summary';
const siteUrl = new URL(withBase(''), Astro.site).toString();
const sameAs = site.socials.map(socialHref).filter(Boolean);
const personSchema = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: site.author,
  url: siteUrl,
  sameAs
});
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href={withBase('sitemap-index.xml')} />
    <link rel="icon" type="image/svg+xml" href={withBase('favicon.svg')} />
    <link rel="apple-touch-icon" href={withBase('apple-touch-icon.png')} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={site.author} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {socialImage && (
      <>
        <meta property="og:image" content={socialImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta name="twitter:image" content={socialImage} />
      </>
    )}
    <script type="application/ld+json" set:html={personSchema}></script>
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <SiteHeader />
    <main class="site-main" id="main-content" tabindex="-1">
      <slot />
    </main>
    <SiteFooter />
  </body>
</html>
