---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CycleTile from '../components/CycleTile.astro';
import { cycles, site } from '../lib/data';
import { assetPath } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

const enabledCycles = cycles.filter((cycle) => !cycle.disabled);
const heroCover = site.headerCover || '';
const heroImage = imageAsset(heroCover);
const socialHero = heroImage
  ? await getImage({ src: heroImage, width: 1200, format: 'jpeg', quality: 80 })
  : undefined;
const ambientAudioSrc = assetPath('audio/ambient.mp3');
---

<BaseLayout
  title={`${site.author} | Writer & Editor`}
  description={site.bio}
  socialImage={socialHero ? { src: socialHero.src } : undefined}
  socialImageAlt={`${site.author} hero image`}
>
  <section class="hero" data-color-reveal>
    {heroCover ? (
      <div class="hero-media">
        <img
          class="hero-image hero-image-mono"
          src={assetPath(heroCover)}
          alt=""
          loading="eager"
          fetchpriority="high"
        />
        <img
          class="hero-image hero-image-color"
          src={assetPath(heroCover)}
          alt=""
          loading="eager"
          aria-hidden="true"
        />
      </div>
    ) : null}
    <div class="hero-inner page-shell">
      <h1 class="hero-title">{site.author}</h1>
      <button
        class="hero-sound"
        type="button"
        aria-pressed="false"
        aria-label="Sound off"
        title="Sound off"
        data-sound-toggle
      >
        <span class="hero-sound-bars" aria-hidden="true"><span></span><span></span><span></span></span>
        <span class="hero-sound-state">Off</span>
      </button>
      <audio src={ambientAudioSrc} preload="none" loop data-ambient-audio></audio>
    </div>
  </section>

  <section class="page-shell cycle-section" aria-label="Cycles">
    <div class="cycle-grid">
      {enabledCycles.map((cycle) => <CycleTile cycle={cycle} />)}
    </div>
  </section>

  <script>
    /* Pointer-driven color reveal for the hero cover. */
    const hero = document.querySelector<HTMLElement>('.hero[data-color-reveal]');
    const canReveal =
      hero &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (canReveal && hero) {
      const heroEl = hero;
      let frame = 0;

      function moveReveal(event: PointerEvent) {
        const rect = heroEl.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;

        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          heroEl.style.setProperty('--reveal-x', x + '%');
          heroEl.style.setProperty('--reveal-y', y + '%');
          heroEl.classList.add('is-color-reveal-active');
        });
      }

      heroEl.addEventListener('pointermove', moveReveal);
      heroEl.addEventListener('pointerenter', moveReveal);
      heroEl.addEventListener('pointerleave', () => {
        heroEl.classList.remove('is-color-reveal-active');
      });
    }

    /* Ambient audio toggle. */
    const soundButton = document.querySelector<HTMLButtonElement>('[data-sound-toggle]');
    const ambientAudio = document.querySelector<HTMLAudioElement>('[data-ambient-audio]');

    if (soundButton && ambientAudio) {
      const toggle = soundButton;
      ambientAudio.volume = 0.32;
      const soundState = toggle.querySelector('.hero-sound-state');

      function setSoundState(label: string, pressed: boolean) {
        toggle.setAttribute('aria-pressed', pressed ? 'true' : 'false');
        toggle.setAttribute('aria-label', 'Sound ' + label.toLowerCase());
        toggle.setAttribute('title', 'Sound ' + label.toLowerCase());
        if (soundState) soundState.textContent = label;
      }

      toggle.addEventListener('click', async () => {
        const isOn = toggle.getAttribute('aria-pressed') === 'true';

        if (isOn) {
          ambientAudio.pause();
          setSoundState('Off', false);
          return;
        }

        try {
          await ambientAudio.play();
          setSoundState('On', true);
        } catch {
          setSoundState('Off', false);
        }
      });

      ambientAudio.addEventListener('ended', () => setSoundState('Off', false));
    }
  </script>
</BaseLayout>
