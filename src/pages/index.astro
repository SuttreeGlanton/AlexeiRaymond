---
import { Picture } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CycleTile from '../components/CycleTile.astro';
import LatestStrip from '../components/LatestStrip.astro';
import TeaserAccordion from '../components/TeaserAccordion.astro';
import { cycles, site } from '../lib/data';
import { assetPath, withBase } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

const headerImage = imageAsset(site.headerCover);
const headerCover = site.headerCover ? assetPath(site.headerCover) : '';
const heroWidths = [640, 960, 1280, 1440, 1600, 1800];
const homeDescription = 'Alexei Raymond is a writer and editor of short fiction, flash, poems, and interconnected story cycles, pursuing visions of unspeakable loveliness.';
---

<BaseLayout
  title={`${site.author} | Writer & Editor`}
  description={homeDescription}
>
  <section class="hero" aria-labelledby="home-title" data-color-reveal>
    {headerImage ? (
      <>
        <Picture
          class="hero-backdrop hero-backdrop--mono"
          src={headerImage}
          alt=""
          widths={heroWidths}
          width={1800}
          sizes="100vw"
          formats={['avif']}
          fallbackFormat="webp"
          quality={55}
          priority
        />
        <Picture
          class="hero-backdrop hero-color-reveal"
          src={headerImage}
          alt=""
          widths={heroWidths}
          width={1800}
          sizes="100vw"
          formats={['avif']}
          fallbackFormat="webp"
          quality={55}
          loading="eager"
          decoding="async"
          aria-hidden="true"
        />
        <div class="hero-scrim" aria-hidden="true"></div>
      </>
    ) : headerCover ? (
      <>
        <img class="hero-backdrop hero-backdrop--mono" src={headerCover} alt="" fetchpriority="high" />
        <img class="hero-backdrop hero-color-reveal" src={headerCover} alt="" aria-hidden="true" loading="eager" />
        <div class="hero-scrim" aria-hidden="true"></div>
      </>
    ) : null}
    <div class="page-shell hero-content">
      <p class="hero-kicker">Short fiction, flash, poems, and the pursuit of unspeakable&nbsp;loveliness.</p>
      <h1 id="home-title">{site.author}</h1>
      <a class="hero-start" href={withBase('selected/')}>New here? Start with Selected Works &rarr;</a>
    </div>

    <div class="hero-teaser-feed">
      <TeaserAccordion />
    </div>

    <style>
      .hero-teaser-feed {
        position: absolute;
        right: clamp(116px, calc(4vw + 94px), 152px);
        bottom: clamp(18px, 4vw, 44px);
        z-index: 3;
        width: min(26rem, calc(100% - 210px));
      }

      @media (max-width: 860px) {
        .hero-teaser-feed {
          position: relative;
          right: auto;
          bottom: auto;
          width: min(calc(100% - 32px), 28rem);
          margin: clamp(26px, 5vw, 36px) 16px 0 auto;
        }
      }

      @media (max-width: 640px) {
        .hero-teaser-feed {
          width: calc(100% - 22px);
          margin: 30px auto 0;
        }
      }
    </style>

    <button class="hero-sound-toggle" type="button" data-sound-toggle aria-pressed="false" aria-label="Sound off" title="Sound off">
      <span class="hero-sound-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M4.5 10v4h4l5 4V6l-5 4h-4z"></path>
          <path class="hero-sound-wave" d="M16.5 8.5c1.4 1.4 1.4 4.6 0 6"></path>
        </svg>
      </span>
      <span class="hero-sound-state">Off</span>
    </button>
    <audio data-ambient-audio src={assetPath('audio/ambient.mp3')} loop preload="none"></audio>
  </section>

  <LatestStrip />

  <section class="page-shell" aria-labelledby="cycles-title">
    <div class="section-head">
      <h2 id="cycles-title">Cycles</h2>
      <p class="section-note">Story cycles flow in and out of one another; an interconnected whole emerges.</p>
    </div>
    <div class="cycle-grid home-cycle-grid" data-home-cycle-focus data-home-cycle-fan>
      {cycles.map((cycle) => (
        <CycleTile cycle={cycle} />
      ))}
    </div>
  </section>

  <script>
    /* Homepage color flashlight: desktop pointer only, reduced-motion safe. */
    const hero = document.querySelector<HTMLElement>('.hero[data-color-reveal]');
    const canReveal =
      hero &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (canReveal && hero) {
      const heroEl = hero;
      let frame = 0;

      function moveReveal(event: PointerEvent) {
        const rect = heroEl.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;

        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          heroEl.style.setProperty('--reveal-x', x + '%');
          heroEl.style.setProperty('--reveal-y', y + '%');
          heroEl.classList.add('is-color-reveal-active');
        });
      }

      heroEl.addEventListener('pointermove', moveReveal);
      heroEl.addEventListener('pointerenter', moveReveal);
      heroEl.addEventListener('pointerleave', () => {
        heroEl.classList.remove('is-color-reveal-active');
      });
    }
  </script>
  <script>
    /* Homepage local ambient sound toggle. */
    const soundButton = document.querySelector<HTMLButtonElement>('[data-sound-toggle]');
    const ambientAudio = document.querySelector<HTMLAudioElement>('[data-ambient-audio]');

    if (soundButton && ambientAudio) {
      const toggle = soundButton;
      ambientAudio.volume = 0.32;
      const soundState = toggle.querySelector('.hero-sound-state');

      function setSoundState(label: string, pressed: boolean) {
        toggle.setAttribute('aria-pressed', pressed ? 'true' : 'false');
        toggle.setAttribute('aria-label', 'Sound ' + label.toLowerCase());
        toggle.setAttribute('title', 'Sound ' + label.toLowerCase());
        if (soundState) soundState.textContent = label;
      }

      toggle.addEventListener('click', async () => {
        const isOn = toggle.getAttribute('aria-pressed') === 'true';

        if (isOn) {
          ambientAudio.pause();
          setSoundState('Off', false);
          return;
        }

        try {
          setSoundState('...', false);
          await ambientAudio.play();
          setSoundState('On', true);
        } catch {
          setSoundState('Unavailable', false);
        }
      });
    }
  </script>

  <script>
    /* Homepage desktop cycle fan focus. */
    (() => {
      const desktop = window.matchMedia('(min-width: 861px)');
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)');
      const fan = document.querySelector<HTMLElement>('[data-home-cycle-fan]');

      if (!fan) return;

      const tiles = Array.from(fan.querySelectorAll<HTMLElement>('.tile'));
      if (!tiles.length) return;

      const defaultTile =
        tiles.find((tile) => tile.dataset.cycleId === 'portici') ??
        tiles[Math.floor(tiles.length / 2)];

      function setFanFocus(focusedTile?: HTMLElement) {
        tiles.forEach((tile) => {
          tile.classList.toggle('is-fan-focus', tile === focusedTile);
        });
      }

      function restoreFanFocus() {
        if (!desktop.matches) {
          setFanFocus();
          return;
        }

        const keyboardTile = tiles.find((tile) => tile.matches(':focus-visible'));
        setFanFocus(keyboardTile ?? defaultTile);
      }

      function playFanEntrance() {
        fan.classList.remove('is-fan-pending');
        fan.classList.add('is-fan-entering');

        window.setTimeout(() => {
          fan.classList.remove('is-fan-entering');
          restoreFanFocus();
        }, 1320);
      }

      function armFanEntrance() {
        if (!desktop.matches || reducedMotion.matches) {
          restoreFanFocus();
          return;
        }

        fan.classList.add('is-fan-pending');
        setFanFocus();

        if (!('IntersectionObserver' in window)) {
          playFanEntrance();
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            if (!entries.some((entry) => entry.isIntersecting)) return;

            observer.disconnect();
            window.setTimeout(playFanEntrance, 180);
          },
          {
            rootMargin: '0px 0px -12% 0px',
            threshold: 0.18,
          },
        );

        observer.observe(fan);
      }

      tiles.forEach((tile) => {
        tile.addEventListener('pointerenter', () => {
          if (
            desktop.matches &&
            !fan.classList.contains('is-fan-pending') &&
            !fan.classList.contains('is-fan-entering')
          ) {
            setFanFocus(tile);
          }
        });

        tile.addEventListener('focusin', () => {
          if (desktop.matches) setFanFocus(tile);
        });
      });

      fan.addEventListener('pointerleave', restoreFanFocus);
      fan.addEventListener('focusout', (event) => {
        const nextTarget = event.relatedTarget;

        if (!(nextTarget instanceof Node) || !fan.contains(nextTarget)) {
          restoreFanFocus();
        }
      });

      if (desktop.addEventListener) {
        desktop.addEventListener('change', restoreFanFocus);
      } else if (desktop.addListener) {
        desktop.addListener(restoreFanFocus);
      }

      armFanEntrance();
    })();
  </script>

  <script>
    /* Homepage mobile cycle focus color. */
    (() => {
      const media = window.matchMedia('(max-width: 640px)');
      const grid = document.querySelector('[data-home-cycle-focus]');

      if (!grid) return;

      const tiles = Array.from(grid.querySelectorAll('.tile'));
      if (!tiles.length) return;

      function updateFocus() {
        if (!media.matches) {
          tiles.forEach((tile) => tile.classList.remove('is-mobile-focus'));
          return;
        }

        const viewportCenter = window.innerHeight / 2;
        let closestTile = tiles[0];
        let closestDistance = Infinity;

        tiles.forEach((tile) => {
          const rect = tile.getBoundingClientRect();
          const tileCenter = rect.top + rect.height / 2;
          const distance = Math.abs(tileCenter - viewportCenter);
          const visible = rect.bottom > 0 && rect.top < window.innerHeight;

          if (visible && distance < closestDistance) {
            closestDistance = distance;
            closestTile = tile;
          }
        });

        tiles.forEach((tile) => {
          tile.classList.toggle('is-mobile-focus', tile === closestTile);
        });
      }

      let frame = 0;

      function scheduleUpdate() {
        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(updateFocus);
      }

      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate);

      if (media.addEventListener) {
        media.addEventListener('change', scheduleUpdate);
      } else if (media.addListener) {
        media.addListener(scheduleUpdate);
      }

      scheduleUpdate();
    })();
  </script>

</BaseLayout>
