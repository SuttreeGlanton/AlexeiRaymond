---
import { getImage } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import CycleTile from '../components/CycleTile.astro';
import { cycles, site } from '../lib/data';
import { assetPath, withBase } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

const headerImage = imageAsset(site.headerCover);
const optimizedHeader = headerImage
  ? await getImage({
      src: headerImage,
      width: 1800,
      format: 'webp',
      quality: 82
    })
  : null;

const headerCover = optimizedHeader?.src || (site.headerCover ? assetPath(site.headerCover) : '');
---

<BaseLayout title={site.author}>
  <section class="hero" aria-labelledby="home-title" data-color-reveal>
    {headerCover && (
      <>
        <img class="hero-backdrop hero-backdrop--mono" src={headerCover} alt="" fetchpriority="high" />
        <img class="hero-backdrop hero-color-reveal" src={headerCover} alt="" aria-hidden="true" loading="eager" />
        <div class="hero-scrim" aria-hidden="true"></div>
      </>
    )}
    <div class="page-shell hero-content">
      <p class="hero-kicker">Short fiction, flash, poems, and the pursuit of unspeakable&nbsp;loveliness.</p>
      <h1 id="home-title">{site.author}</h1>
      <a class="hero-start" href={withBase('selected/')}>New here? Start with Selected Works &rarr;</a>
    </div>

    <button class="hero-sound-toggle" type="button" data-sound-toggle aria-pressed="false" aria-label="Sound off" title="Sound off">
      <span class="hero-sound-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" focusable="false">
          <path d="M4.5 10v4h4l5 4V6l-5 4h-4z"></path>
          <path class="hero-sound-wave" d="M16.5 8.5c1.4 1.4 1.4 4.6 0 6"></path>
        </svg>
      </span>
      <span class="hero-sound-state">Off</span>
    </button>
    <audio data-ambient-audio src={assetPath('audio/ambient.mp3')} loop preload="none"></audio>
  </section>

  <section class="page-shell" aria-labelledby="cycles-title">
    <div class="section-head">
      <h2 id="cycles-title">Cycles</h2>
      <p class="section-note">Published and forthcoming work, arranged by recurring cycle rather than chronology.</p>
    </div>
    <div class="cycle-grid home-cycle-grid" data-home-cycle-focus>
      {cycles.map((cycle) => (
        <CycleTile cycle={cycle} />
      ))}
    </div>
  </section>

  <script>
    /* Homepage color flashlight: desktop pointer only, reduced-motion safe. */
    const hero = document.querySelector('.hero[data-color-reveal]');
    const canReveal =
      hero &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (canReveal) {
      let frame = 0;

      function moveReveal(event) {
        const rect = hero.getBoundingClientRect();
        const x = ((event.clientX - rect.left) / rect.width) * 100;
        const y = ((event.clientY - rect.top) / rect.height) * 100;

        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          hero.style.setProperty('--reveal-x', x + '%');
          hero.style.setProperty('--reveal-y', y + '%');
          hero.classList.add('is-color-reveal-active');
        });
      }

      hero.addEventListener('pointermove', moveReveal);
      hero.addEventListener('pointerenter', moveReveal);
      hero.addEventListener('pointerleave', () => {
        hero.classList.remove('is-color-reveal-active');
      });
    }
  </script>
  <script>
    /* Homepage local ambient sound toggle. */
    const soundButton = document.querySelector('[data-sound-toggle]');
    const ambientAudio = document.querySelector('[data-ambient-audio]');

    if (soundButton && ambientAudio) {
      ambientAudio.volume = 0.32;
      const soundState = soundButton.querySelector('.hero-sound-state');

      function setSoundState(label, pressed) {
        soundButton.setAttribute('aria-pressed', pressed ? 'true' : 'false');
        soundButton.setAttribute('aria-label', 'Sound ' + label.toLowerCase());
        soundButton.setAttribute('title', 'Sound ' + label.toLowerCase());
        if (soundState) soundState.textContent = label;
      }

      soundButton.addEventListener('click', async () => {
        const isOn = soundButton.getAttribute('aria-pressed') === 'true';

        if (isOn) {
          ambientAudio.pause();
          setSoundState('Off', false);
          return;
        }

        try {
          setSoundState('...', false);
          await ambientAudio.play();
          setSoundState('On', true);
        } catch {
          setSoundState('Unavailable', false);
        }
      });
    }
  </script>

  <script>
    /* Homepage mobile cycle focus color. */
    (() => {
      const media = window.matchMedia('(max-width: 640px)');
      const grid = document.querySelector('[data-home-cycle-focus]');

      if (!grid) return;

      const tiles = Array.from(grid.querySelectorAll('.tile'));
      if (!tiles.length) return;

      function updateFocus() {
        if (!media.matches) {
          tiles.forEach((tile) => tile.classList.remove('is-mobile-focus'));
          return;
        }

        const viewportCenter = window.innerHeight / 2;
        let closestTile = tiles[0];
        let closestDistance = Infinity;

        tiles.forEach((tile) => {
          const rect = tile.getBoundingClientRect();
          const tileCenter = rect.top + rect.height / 2;
          const distance = Math.abs(tileCenter - viewportCenter);
          const visible = rect.bottom > 0 && rect.top < window.innerHeight;

          if (visible && distance < closestDistance) {
            closestDistance = distance;
            closestTile = tile;
          }
        });

        tiles.forEach((tile) => {
          tile.classList.toggle('is-mobile-focus', tile === closestTile);
        });
      }

      let frame = 0;

      function scheduleUpdate() {
        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(updateFocus);
      }

      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate);

      if (media.addEventListener) {
        media.addEventListener('change', scheduleUpdate);
      } else if (media.addListener) {
        media.addListener(scheduleUpdate);
      }

      scheduleUpdate();
    })();
  </script>

</BaseLayout>
