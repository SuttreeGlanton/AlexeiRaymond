---
import BaseLayout from '../layouts/BaseLayout.astro';
import CycleTile from '../components/CycleTile.astro';
import { cycles, pieces, pieceCountForCycle, site, upcomingPieces } from '../lib/data';

const publishedCount = pieces.length - upcomingPieces().length;
---

<BaseLayout title={site.author}>
  <section class="page-shell hero" aria-labelledby="home-title">
    <div class="eyebrow">Author website</div>
    <h1 id="home-title">{site.author}</h1>
    <p class="hero-line">{publishedCount} published · {upcomingPieces().length} upcoming · {cycles.length} cycles</p>
  </section>

  <section class="page-shell" aria-labelledby="cycles-title">
    <div class="section-head">
      <h2 id="cycles-title">Cycles</h2>
      <p class="section-note">Seven rooms for the work. Counts are drawn directly from the site data.</p>
    </div>
    <div class="cycle-grid">
      {cycles.map((cycle) => (
        <CycleTile cycle={cycle} count={pieceCountForCycle(cycle.name)} />
      ))}
    </div>
  </section>
</BaseLayout>
