---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, socialHref, socialLabel } from '../lib/data';

const hasEmail = Boolean(site.email);
const hasSocials = site.socials.length > 0;
---

<BaseLayout title={`Contact — ${site.author}`}>
  <section class="page-shell page-hero text-page" aria-labelledby="contact-title">
    <div class="overline">Contact</div>
    <h1 class="page-title" id="contact-title">Contact</h1>

    {hasEmail || hasSocials ? (
      <ul class="contact-list">
        {hasEmail && <li><a href={`mailto:${site.email}`}>{site.email}</a></li>}
        {site.socials.map((social) => {
          const href = socialHref(social);
          const label = socialLabel(social);
          return <li>{href ? <a href={href} target="_blank" rel="noreferrer">{label}</a> : <span>{label}</span>}</li>;
        })}
      </ul>
    ) : (
      <p class="placeholder-copy">No public contact information is listed yet.</p>
    )}
  </section>
</BaseLayout>
