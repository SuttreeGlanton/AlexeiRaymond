---
import OptimizedImage from '../components/OptimizedImage.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatMonthYear, interview, site } from '../lib/data';
import { imageAsset } from '../lib/image-assets';

const cover = interview.cover || '';
const coverImage = imageAsset(interview.cover);
---

<BaseLayout title={`Elsewhere — ${site.author}`} description="Interviews, conversations, and other traces outside the bibliography.">
  <section class="page-shell page-hero text-page" aria-labelledby="elsewhere-title">
    <h1 class="page-title" id="elsewhere-title">Elsewhere</h1>
    <p class="page-intro cycle-intro">Interviews, conversations, and other traces outside the bibliography.</p>

    <article class="interview-card" data-interview-color-card>
      <div class="interview-media">
        {cover ? (
          <OptimizedImage
            path={cover}
            image={coverImage}
            alt={interview.title}
            loading="lazy"
            sizes="(max-width: 640px) 92vw, (max-width: 960px) 44vw, 420px"
            widths={[240, 400, 560, 760]}
          />
        ) : (
          <div class="placeholder" aria-hidden="true"><span>{interview.publication}</span></div>
        )}
      </div>
      <div class="interview-body">
        <h2>{interview.title}</h2>
        <p class="interview-meta">{interview.publication} · {formatMonthYear(interview.date)}</p>
        {interview.excerpt && <p class="interview-excerpt">&ldquo;{interview.excerpt}&rdquo;</p>}
        <a class="interview-link" href={interview.link} target="_blank" rel="noopener noreferrer" aria-label={`Read ${interview.title}. Opens in a new tab.`}>Read interview</a>
      </div>
    </article>
  </section>

  <script>
    /* Elsewhere interview mobile color focus. */
    (() => {
      const card = document.querySelector('[data-interview-color-card]');
      const media = window.matchMedia('(max-width: 640px)');

      if (!card) return;

      function updateFocus() {
        if (!media.matches) {
          card.classList.remove('is-mobile-focus');
          return;
        }

        const rect = card.getBoundingClientRect();
        const viewportCenter = window.innerHeight / 2;
        const focused = rect.top < viewportCenter && rect.bottom > viewportCenter;

        card.classList.toggle('is-mobile-focus', focused);
      }

      let frame = 0;

      function scheduleUpdate() {
        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(updateFocus);
      }

      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate);

      if (media.addEventListener) {
        media.addEventListener('change', scheduleUpdate);
      } else if (media.addListener) {
        media.addListener(scheduleUpdate);
      }

      scheduleUpdate();
    })();
  </script>

</BaseLayout>
