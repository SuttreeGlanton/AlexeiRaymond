---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import TagList from '../components/TagList.astro';
import chronologyVisual from '../assets/page-visuals/chronology-records.jpg';
import { canLinkToPiece, cycleByName, cycleNamesForPiece, formatIsoDate, formatMonthYear, parseDate, publishedNewestFirst, site, upcomingPieces, publicationLabel } from '../lib/data';
import { withBase } from '../lib/paths';

const upcoming = upcomingPieces();
const published = publishedNewestFirst();
const chronologyWidths = [720, 960, 1080, 1200, 1400];
const chronologySizes = '(max-width: 1080px) 1px, (max-width: 1687px) 64vw, 1080px';

function dateTimestamp(date) {
  return parseDate(date)?.getTime() ?? 0;
}

function cycleLinksForPiece(piece) {
  return cycleNamesForPiece(piece)
    .map((name) => cycleByName.get(name))
    .filter(Boolean);
}
---

<BaseLayout title={`Chronology — ${site.author}`} description="A chronological bibliography of published and forthcoming work.">
  <div class="page-shell page-with-visual chronology-with-visual">
    <div class="page-copy">
      <section class="page-hero" aria-labelledby="chronology-title">
        <h1 class="page-title" id="chronology-title">Chronology</h1>
        <p class="page-intro cycle-intro">A chronological bibliography of published and forthcoming work.</p>
      </section>

      {upcoming.length > 0 && (
        <section class="chronology-section chronology-upcoming" aria-labelledby="upcoming-title">
          <h2 id="upcoming-title">Upcoming</h2>
          <ul class="chronology-list">
            {upcoming.map((piece) => {
              const pieceCycles = cycleLinksForPiece(piece);

              return (
                <li class="chronology-item">
                  <h3 class="chronology-piece-title">
                    <span aria-hidden="true">&ldquo;</span>{piece.title}<span aria-hidden="true">&rdquo;</span>
                  </h3>
                  <p class="chronology-publication-line">
                    Forthcoming in <span class="pub">{publicationLabel(piece)}</span>
                  </p>
                  <div class="chronology-tags">
                    <TagList tags={piece.tags.filter((tag) => tag !== 'Upcoming')} genre={piece.genre} />
                  </div>
                  <div class="chronology-cycle-links" aria-label={`${pieceCycles.length > 1 ? 'Cycles' : 'Cycle'} for ${piece.title}`}>
                    <span>{pieceCycles.length > 1 ? 'Cycles' : 'Cycle'}</span>
                    {pieceCycles.map((cycle, index) => (
                      <>
                        {index > 0 && <span aria-hidden="true">·</span>}
                        <a href={withBase(`cycles/${cycle.id}/`)}>{cycle.name}</a>
                      </>
                    ))}
                  </div>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      <section class="chronology-section" aria-labelledby="published-title">
        <div class="chronology-heading-row">
          <h2 id="published-title">Published</h2>
          <div class="chronology-sort" aria-label="Sort published pieces">
            <button type="button" class="sort-button is-active" data-sort-order="newest" aria-label="Sort latest first" aria-pressed="true">Latest</button>
            <button type="button" class="sort-button" data-sort-order="oldest" aria-label="Sort earliest first" aria-pressed="false">Earliest</button>
            <button type="button" class="sort-button" data-sort-order="onsite" aria-label="Place works readable on this site first" aria-pressed="false">Read here</button>
          </div>
        </div>

        <ul class="chronology-list" data-published-list>
          {published.map((piece, index) => {
            const year = parseDate(piece.date)?.getFullYear();
            const previousYear = index > 0 ? parseDate(published[index - 1].date)?.getFullYear() : null;
            const pieceCycles = cycleLinksForPiece(piece);
            const monthYear = formatMonthYear(piece.date);

            return (
              <>
                {year && year !== previousYear && (
                  <li class="chron-year-sep" data-sort-separator aria-hidden="true">{year}</li>
                )}
                <li
                  class="chronology-item"
                  data-date={dateTimestamp(piece.date)}
                  data-on-site={piece.account?.slug ? 'true' : 'false'}
                >
                  <div class="chronology-title-row">
                    <h3 class="chronology-piece-title">
                      <span aria-hidden="true">&ldquo;</span>{canLinkToPiece(piece) ? (
                        <a href={piece.link} target="_blank" rel="noopener noreferrer" aria-label={`Read ${piece.title} at ${publicationLabel(piece)}. Opens in a new tab.`}>{piece.title}</a>
                      ) : (
                        piece.title
                      )}<span aria-hidden="true">&rdquo;</span>
                    </h3>
                    {piece.account && (
                      <a class="chronology-read-link" href={withBase(`accounts/${piece.account.slug}/`)} aria-label={`Read story: ${piece.title} on this site`}>
                        Read story <span aria-hidden="true">&rarr;</span>
                      </a>
                    )}
                  </div>
                  <p class="chronology-publication-line">
                    First published in <span class="pub">{publicationLabel(piece)}</span>
                    {monthYear && (
                      <>
                        <span class="chronology-publication-separator" aria-hidden="true">&middot;</span>
                        <time datetime={formatIsoDate(piece.date)}>{monthYear}</time>
                      </>
                    )}
                  </p>
                  <div class="chronology-tags">
                    <TagList tags={piece.tags} genre={piece.genre} />
                  </div>
                  <div class="chronology-cycle-links" aria-label={`${pieceCycles.length > 1 ? 'Cycles' : 'Cycle'} for ${piece.title}`}>
                    <span>{pieceCycles.length > 1 ? 'Cycles' : 'Cycle'}</span>
                    {pieceCycles.map((cycle, index) => (
                      <>
                        {index > 0 && <span aria-hidden="true">·</span>}
                        <a href={withBase(`cycles/${cycle.id}/`)}>{cycle.name}</a>
                      </>
                    ))}
                  </div>
                </li>
              </>
            );
          })}
        </ul>
      </section>
    </div>

    <aside class="page-visual chronology-visual" aria-hidden="true" data-chronology-visual>
      <Image
        src={chronologyVisual}
        alt=""
        widths={chronologyWidths}
        sizes={chronologySizes}
        format="webp"
        quality={82}
        loading="lazy"
        decoding="async"
      />
      <Image
        class="chronology-color"
        src={chronologyVisual}
        alt=""
        widths={chronologyWidths}
        sizes={chronologySizes}
        format="webp"
        quality={82}
        loading="lazy"
        decoding="async"
        aria-hidden="true"
      />
    </aside>
  </div>

  <script>
    const list = document.querySelector('[data-published-list]');
    const buttons = Array.from(document.querySelectorAll('[data-sort-order]'));

    function renderSeparators(order) {
      if (!list) return;

      list.querySelectorAll('[data-sort-separator]').forEach((node) => node.remove());

      const items = Array.from(list.querySelectorAll('.chronology-item'));

      if (order === 'onsite') {
        let lastGroup = '';

        for (const item of items) {
          const group = item.dataset.onSite === 'true' ? 'onsite' : 'other';

          if (group !== lastGroup) {
            const separator = document.createElement('li');
            separator.className = 'chron-year-sep chron-group-sep';
            separator.dataset.sortSeparator = '';
            separator.textContent = group === 'onsite' ? 'Available here' : 'Other publications';
            list.insertBefore(separator, item);
            lastGroup = group;
          }
        }

        return;
      }

      let lastYear = null;

      for (const item of items) {
        const timestamp = Number(item.dataset.date || 0);
        const year = timestamp ? new Date(timestamp).getFullYear() : null;

        if (year && year !== lastYear) {
          const separator = document.createElement('li');
          separator.className = 'chron-year-sep';
          separator.dataset.sortSeparator = '';
          separator.setAttribute('aria-hidden', 'true');
          separator.textContent = String(year);
          list.insertBefore(separator, item);
          lastYear = year;
        }
      }
    }

    function sortPublished(order) {
      if (!list) return;

      const items = Array.from(list.querySelectorAll('.chronology-item'));

      items.sort((a, b) => {
        const first = Number(a.dataset.date || 0);
        const second = Number(b.dataset.date || 0);

        if (order === 'onsite') {
          const firstOnSite = a.dataset.onSite === 'true';
          const secondOnSite = b.dataset.onSite === 'true';

          if (firstOnSite !== secondOnSite) {
            return firstOnSite ? -1 : 1;
          }
        }

        return order === 'oldest' ? first - second : second - first;
      });

      for (const item of items) {
        list.appendChild(item);
      }

      renderSeparators(order);

      for (const button of buttons) {
        const active = button.dataset.sortOrder === order;
        button.classList.toggle('is-active', active);
        button.setAttribute('aria-pressed', active ? 'true' : 'false');
      }
    }

    renderSeparators('newest');

    for (const button of buttons) {
      button.addEventListener('click', () => {
        sortPublished(button.dataset.sortOrder || 'newest');
      });
    }
  </script>

  <script>
    /* Chronology photo color flashlight: desktop pointer only, reduced-motion safe. */
    const visual = document.querySelector('[data-chronology-visual]');
    const container = document.querySelector('.chronology-with-visual');
    const canReveal =
      visual &&
      container &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (canReveal) {
      let frame = 0;

      function moveReveal(event) {
        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          const rect = visual.getBoundingClientRect();
          visual.style.setProperty('--reveal-x', (event.clientX - rect.left) + 'px');
          visual.style.setProperty('--reveal-y', (event.clientY - rect.top) + 'px');
          visual.classList.add('is-color-reveal-active');
        });
      }

      container.addEventListener('pointermove', moveReveal);
      container.addEventListener('pointerleave', () => {
        visual.classList.remove('is-color-reveal-active');
      });
    }
  </script>
</BaseLayout>
