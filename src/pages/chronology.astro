---
import BaseLayout from '../layouts/BaseLayout.astro';
import OptimizedImage from '../components/OptimizedImage.astro';
import { canLinkToPiece, cycleByName, cycleNamesForPiece, formatIsoDate, formatMonthYear, parseDate, pieces, publishedNewestFirst, site, upcomingPieces, publicationLabel } from '../lib/data';
import { withBase } from '../lib/paths';
import { imageAsset } from '../lib/image-assets';

const published = publishedNewestFirst();
const upcoming = upcomingPieces();

function dateTimestamp(date: string | null) {
  return parseDate(date)?.getTime() ?? 0;
}

function cycleLinksForPiece(piece: (typeof pieces)[number]) {
  return cycleNamesForPiece(piece)
    .map((name) => cycleByName.get(name))
    .filter((cycle): cycle is NonNullable<typeof cycle> => Boolean(cycle));
}
---

<BaseLayout title={`Chronology — ${site.author}`} description="Every published piece, newest to oldest.">
  <div class="page-shell chronology-shell">
    <section class="page-hero chronology-hero" aria-labelledby="chronology-title">
      <h1 class="page-title" id="chronology-title">Chronology</h1>
      <div class="chronology-sort" role="group" aria-label="Sort published pieces">
        <button type="button" class="sort-button is-active" data-sort-order="newest" aria-pressed="true">Newest first</button>
        <button type="button" class="sort-button" data-sort-order="oldest" aria-pressed="false">Oldest first</button>
      </div>
    </section>

    <div class="chronology-with-visual">
      <div class="chronology-main">
        {upcoming.length > 0 && (
          <section class="chronology-upcoming" aria-labelledby="upcoming-title">
            <h2 id="upcoming-title">Upcoming</h2>
            <ul class="chronology-list">
              {upcoming.map((piece) => (
                <li class="chronology-item chronology-item-upcoming">
                  <article class="chronology-piece">
                    <header class="chronology-piece-header">
                      <h3>{piece.title}</h3>
                      <div class="chronology-badges" aria-label="Piece details">
                        <span class="status-badge status-badge-upcoming">Upcoming</span>
                      </div>
                    </header>
                    <div class="chronology-meta">
                      <span>Forthcoming in <span class="card-publication">{piece.publication}</span></span>
                      {cycleLinksForPiece(piece).map((cycle) => (
                        <a class="chronology-cycle" href={withBase(`cycles/${cycle.id}/`)}>{cycle.name}</a>
                      ))}
                    </div>
                  </article>
                </li>
              ))}
            </ul>
          </section>
        )}

        <section aria-label="Published pieces">
          <h2 class="sr-only">Published</h2>
          <ul class="chronology-list" data-published-list>
            {published.map((piece) => {
              const linked = canLinkToPiece(piece);
              return (
                <li
                  class="chronology-item"
                  data-date={formatIsoDate(piece.date)}
                  data-timestamp={dateTimestamp(piece.date)}
                  data-year={parseDate(piece.date)?.getFullYear()}
                >
                  <article class="chronology-piece">
                    <header class="chronology-piece-header">
                      <h3>
                        {linked ? (
                          <a href={piece.link} target="_blank" rel="noopener noreferrer" aria-label={`Read ${piece.title} at ${publicationLabel(piece)}. Opens in a new tab.`}>{piece.title}</a>
                        ) : (
                          piece.title
                        )}
                      </h3>
                      <div class="chronology-badges" aria-label="Piece details">
                        {piece.genre && <span class="status-badge status-badge-genre">{piece.genre}</span>}
                      </div>
                    </header>
                    <div class="chronology-meta">
                      <span class="card-publication">{piece.publication}</span>
                      {piece.issue && <span>{piece.issue}</span>}
                      <span>{formatMonthYear(piece.date)}</span>
                      {cycleLinksForPiece(piece).map((cycle) => (
                        <a class="chronology-cycle" href={withBase(`cycles/${cycle.id}/`)}>{cycle.name}</a>
                      ))}
                    </div>
                  </article>
                </li>
              );
            })}
          </ul>
        </section>
      </div>

      <aside class="page-visual chronology-visual" aria-hidden="true" data-chronology-visual>
        <OptimizedImage
          path="page-visuals/chronology.jpg"
          image={imageAsset('page-visuals/chronology.jpg')}
          alt=""
          loading="lazy"
          sizes="(max-width: 860px) 1px, 38vw"
          widths={[360, 540, 720, 1080]}
        />
      </aside>
    </div>
  </div>

  <script>
    const list = document.querySelector<HTMLElement>('[data-published-list]');
    const buttons = Array.from(document.querySelectorAll<HTMLElement>('[data-sort-order]'));

    function renderSeparators(order: string) {
      if (!list) return;

      list.querySelectorAll('[data-sort-separator]').forEach((node) => node.remove());

      const items = Array.from(list.querySelectorAll<HTMLElement>('.chronology-item'));
      let lastYear: number | null = null;

      for (const item of items) {
        const year = Number(item.dataset.year);
        if (lastYear !== null && year !== lastYear) {
          const separator = document.createElement('li');
          separator.className = 'chronology-separator';
          separator.setAttribute('data-sort-separator', '');
          separator.setAttribute('aria-hidden', 'true');
          list.insertBefore(separator, item);
        }
        lastYear = year;
      }
    }

    function sortPublished(order: string) {
      if (!list) return;

      const items = Array.from(list.querySelectorAll<HTMLElement>('.chronology-item'));
      items.sort((a, b) => {
        const aTime = Number(a.dataset.timestamp || '0');
        const bTime = Number(b.dataset.timestamp || '0');
        return order === 'oldest' ? aTime - bTime : bTime - aTime;
      });

      for (const item of items) {
        list.appendChild(item);
      }

      renderSeparators(order);
    }

    for (const button of buttons) {
      button.addEventListener('click', () => {
        const order = button.dataset.sortOrder;
        if (!order) return;

        sortPublished(order);

        for (const candidate of buttons) {
          const active = candidate === button;
          candidate.classList.toggle('is-active', active);
          candidate.setAttribute('aria-pressed', active ? 'true' : 'false');
        }
      });
    }

    renderSeparators('newest');
  </script>

  <script>
    /* Pointer-driven color reveal for the chronology visual. */
    const visual = document.querySelector<HTMLElement>('[data-chronology-visual]');
    const container = document.querySelector<HTMLElement>('.chronology-with-visual');
    const canReveal =
      visual &&
      container &&
      window.matchMedia('(hover: hover) and (pointer: fine)').matches &&
      !window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (canReveal && visual && container) {
      const visualEl = visual;
      let frame = 0;

      function moveReveal(event: PointerEvent) {
        cancelAnimationFrame(frame);
        frame = requestAnimationFrame(() => {
          const rect = visualEl.getBoundingClientRect();
          visualEl.style.setProperty('--reveal-x', (event.clientX - rect.left) + 'px');
          visualEl.style.setProperty('--reveal-y', (event.clientY - rect.top) + 'px');
          visualEl.classList.add('is-color-reveal-active');
        });
      }

      container.addEventListener('pointermove', moveReveal);
      container.addEventListener('pointerleave', () => {
        visualEl.classList.remove('is-color-reveal-active');
      });
    }
  </script>
</BaseLayout>
