---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { canLinkToPiece, cycleByName, isDefunct, pieces, site, formatLongDate, publicationLabel } from '../../lib/data';
import { withBase } from '../../lib/paths';

export async function getStaticPaths() {
  const entries = await getCollection('accounts');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const piece = pieces.find((p) => p.account?.slug === entry.id);
const cycle = piece ? cycleByName.get(piece.cycle) : undefined;
const archived = piece ? isDefunct(piece) : false;
const overlineLabel = archived ? 'Archived piece' : 'Account';
const title = entry.data.title || (piece ? `Account of ${piece.title}` : 'Account');
const backHref = cycle ? withBase(`cycles/${cycle.id}/`) : withBase('');
const backLabel = cycle ? cycle.name : 'All cycles';
const metaParts = piece ? [publicationLabel(piece), formatLongDate(piece.date)].filter(Boolean) : [];
const archiveDescription = piece
  ? `${piece.title} by ${site.author}. Originally published in ${publicationLabel(piece)}${formatLongDate(piece.date) ? `, ${formatLongDate(piece.date)}` : ''}.`
  : site.bio;
---

<BaseLayout title={`${title} \u2014 ${site.author}`} description={archiveDescription}>
  <article class={`page-shell page-hero text-page${archived ? ' archived-piece-page' : ''}${entry.data.epigraph ? ' has-epigraph' : ''}`} aria-labelledby="account-title">
    <a class="back-link" href={backHref}>&larr; {backLabel}</a>
    <div class="overline">{overlineLabel}</div>
    <h1 class="page-title account-title" id="account-title">{title}</h1>
    {metaParts.length > 0 && <p class="account-meta">{metaParts.join(' · ')}</p>}
    <div class="prose">
      <Content />
    </div>
    {piece && canLinkToPiece(piece) && (
      <p class="account-outbound">
        <a href={piece.link} target="_blank" rel="noreferrer">Read “{piece.title}” at {piece.publication} &rarr;</a>
      </p>
    )}
  </article>
</BaseLayout>

<style>
  .account-title {
    font-size: clamp(2.4rem, 6vw, 5rem);
  }

  .account-meta {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .account-outbound {
    margin: 34px 0 0;
    font-size: 0.9rem;
  }

  .account-outbound a {
    border-bottom: 1px solid var(--border-strong);
    color: var(--text-soft);
    transition: border-color 240ms ease, color 240ms ease;
  }

  .account-outbound a:hover,
  .account-outbound a:focus-visible {
    border-color: var(--text);
    color: var(--text);
  }
</style>
