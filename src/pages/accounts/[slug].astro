---
import { getCollection, render } from 'astro:content';
import { getImage } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import OptimizedImage from '../../components/OptimizedImage.astro';
import AlleyMoneyCoda from '../../components/AlleyMoneyCoda.astro';
import FatherFrostCoda from '../../components/FatherFrostCoda.astro';
import { canLinkToPiece, cycleByName, isDefunct, pieces, site, formatIsoDate, formatLongDate, formatShortDate, publicationLabel } from '../../lib/data';
import { absoluteSiteUrl, withBase } from '../../lib/paths';
import { imageAsset } from '../../lib/image-assets';

export async function getStaticPaths() {
  const entries = await getCollection('accounts');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const piece = pieces.find((p) => p.account?.slug === entry.id);
const cycle = piece ? cycleByName.get(piece.cycle) : undefined;
const archived = piece ? isDefunct(piece) : false;
const fullText = entry.data.fullText === true;
const isLog = entry.data.format === 'log';
const isTracked = entry.data.format === 'tracked';
const isGenesis = entry.id === 'genesis';
const isAlleyMoney = entry.id === 'alley-money';
const isFatherFrost = entry.id === 'father-frost';
const archivePresentation = archived || fullText;
const overlineLabel = archived ? 'Archived piece' : fullText ? 'In full' : 'Account';
const title = entry.data.title || (piece ? `Account of ${piece.title}` : 'Account');
const backHref = cycle ? withBase(`cycles/${cycle.id}/`) : withBase('');
const backLabel = cycle ? cycle.name : 'All cycles';
const originalPublication = piece ? publicationLabel(piece) : '';
const archiveDescription = piece
  ? `${piece.title} by ${site.author}. Originally published in ${originalPublication}${formatLongDate(piece.date) ? `, ${formatLongDate(piece.date)}` : ''}.`
  : site.bio;
const archiveCoverImage = piece?.cover ? imageAsset(piece.cover) : undefined;
const archiveCoverAlt = piece ? `${piece.title} cover` : '';
const archiveDateLabel = piece ? formatShortDate(piece.date) : '';
const archiveGenreLabels: Record<string, string> = {
  'Short fiction': 'Short fiction',
  'Flash fiction': 'Flash',
  'Poem': 'Poem',
  'Non-fiction': 'Non-fiction',
  'Other': 'Other'
};
const archiveGenreLabel = piece?.genre ? (archiveGenreLabels[piece.genre] ?? piece.genre) : '';
const archiveGenreSlug = piece?.genre ? piece.genre.toLowerCase().replace(/[^a-z]+/g, '-') : '';
const seoGenreLabels: Record<string, string> = {
  'Short fiction': 'Short Fiction',
  'Flash fiction': 'Flash Fiction',
  'Poem': 'Poem',
  'Non-fiction': 'Non-fiction',
  'Other': 'Writing'
};
const seoGenreLabel = piece?.genre ? (seoGenreLabels[piece.genre] ?? piece.genre) : 'Writing';
const seoTitle = fullText && piece
  ? `${piece.title} \u2014 ${seoGenreLabel} by ${site.author}`
  : `${title} \u2014 ${site.author}`;
const seoDescription = fullText && piece
  ? `${piece.genre ?? 'Writing'} by ${site.author}, originally published in ${originalPublication}.${piece.excerpt ? ` ${piece.excerpt}` : ''}`
  : archiveDescription;
const publishedIso = fullText && piece ? formatIsoDate(piece.date) : '';
const accountUrl = absoluteSiteUrl(`accounts/${entry.id}/`, Astro.site);
const authorUrl = absoluteSiteUrl('', Astro.site);
const socialCover = fullText && archiveCoverImage
  ? await getImage({ src: archiveCoverImage, width: 1200, format: 'jpeg', quality: 80 })
  : undefined;
const coverUrl = socialCover ? absoluteSiteUrl(socialCover.src, Astro.site) : '';
const workSchema = fullText && piece ? {
  '@context': 'https://schema.org',
  '@type': piece.genre === 'Short fiction' || piece.genre === 'Flash fiction' ? 'ShortStory' : 'CreativeWork',
  '@id': `${accountUrl}#work`,
  name: piece.title,
  url: accountUrl,
  mainEntityOfPage: accountUrl,
  description: seoDescription,
  author: {
    '@type': 'Person',
    '@id': `${authorUrl}#person`,
    name: site.author,
    url: authorUrl
  },
  ...(piece.genre ? { genre: piece.genre } : {}),
  ...(publishedIso ? { datePublished: publishedIso } : {}),
  ...(piece.publication ? {
    publisher: {
      '@type': 'Organization',
      name: piece.publication
    }
  } : {}),
  ...(originalPublication ? {
    isPartOf: {
      '@type': 'CreativeWork',
      name: originalPublication
    }
  } : {}),
  ...(coverUrl ? { image: coverUrl } : {}),
  inLanguage: 'en',
  isAccessibleForFree: true
} : undefined;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  socialImage={socialCover ? { src: socialCover.src, width: Number(socialCover.attributes.width) || undefined, height: Number(socialCover.attributes.height) || undefined } : undefined}
  socialImageAlt={fullText && piece ? archiveCoverAlt : undefined}
  ogType={fullText && piece ? 'article' : 'website'}
  publishedTime={publishedIso || undefined}
  structuredData={workSchema}
>
  <article class={`page-shell page-hero text-page${archivePresentation ? ' archived-piece-page' : ''}${isLog ? ' archived-piece-page--log' : ''}${isTracked ? ' archived-piece-page--tracked' : ''}${isGenesis ? ' archived-piece-page--genesis' : ''}${isAlleyMoney ? ' archived-piece-page--alley-money' : ''}${entry.data.epigraph ? ' has-epigraph' : ''}`} aria-labelledby="account-title">
    <a class="back-link" href={backHref}>&larr; {backLabel}</a>
    <div class="overline">{overlineLabel}</div>
    <h1 class="page-title account-title" id="account-title">
      {entry.id === 'his-green-delight' ? (
        <>His <span class="hgd-green">Green</span> Delight</>
      ) : title}
    </h1>
    {piece && (piece.publication || piece.issue || formatLongDate(piece.date)) && (
      <p class="account-meta">
        {piece.publication && <span class="card-publication">{piece.publication}</span>}
        {piece.issue && <> {piece.issue}</>}
        {formatLongDate(piece.date) && <> &middot; {formatLongDate(piece.date)}</>}
      </p>
    )}
    <div class={`archive-body-shell${piece?.cover ? ' has-archive-cover' : ''}`}>
      {piece?.cover && (
        <aside class="archive-cover-card" aria-label={`${archiveCoverAlt} and publication details`} tabindex="0" data-archive-mobile-focus>
          <div class="archive-cover-media">
            <OptimizedImage
              path={piece.cover}
              image={archiveCoverImage}
              alt={archiveCoverAlt}
              loading="eager"
              sizes="(max-width: 640px) 76vw, (max-width: 860px) 42vw, 280px"
            />
            {archiveGenreLabel && <span class="genre-mark" data-genre={archiveGenreSlug}>{archiveGenreLabel}</span>}
            {archiveDateLabel && <span class="date-mark">{archiveDateLabel}</span>}
            {piece.excerpt && (
              <div class="card-overlay" aria-hidden="true">
                <p class="card-excerpt">&ldquo;{piece.excerpt}&rdquo;</p>
              </div>
            )}
          </div>
        </aside>
      )}
      <div class="prose archive-prose">
        <Content />
        {isAlleyMoney && <AlleyMoneyCoda />}
        {isFatherFrost && <FatherFrostCoda />}
      </div>
    </div>
    {piece && canLinkToPiece(piece) && (
      <p class="account-outbound">
        <a href={piece.link} target="_blank" rel="noreferrer">Read &ldquo;{piece.title}&rdquo; at <span class="card-publication">{piece.publication}</span> &rarr;</a>
      </p>
    )}
  </article>

  <script>
    /* Archive cover mobile color focus. */
    const archiveCover = document.querySelector('[data-archive-mobile-focus]');
    const archiveCoverQuery = window.matchMedia('(max-width: 640px)');
    let archiveCoverTicking = false;

    function updateArchiveCoverFocus() {
      archiveCoverTicking = false;

      if (!(archiveCover instanceof HTMLElement)) return;

      if (!archiveCoverQuery.matches) {
        archiveCover.classList.remove('is-mobile-focus');
        return;
      }

      const rect = archiveCover.getBoundingClientRect();
      const focusLine = window.innerHeight * 0.52;
      const isFocused = rect.top <= focusLine && rect.bottom >= focusLine;

      archiveCover.classList.toggle('is-mobile-focus', isFocused);
    }

    function scheduleArchiveCoverFocus() {
      if (archiveCoverTicking) return;
      archiveCoverTicking = true;
      requestAnimationFrame(updateArchiveCoverFocus);
    }

    if (archiveCover) {
      updateArchiveCoverFocus();
      window.addEventListener('scroll', scheduleArchiveCoverFocus, { passive: true });
      window.addEventListener('resize', scheduleArchiveCoverFocus);

      if (typeof archiveCoverQuery.addEventListener === 'function') {
        archiveCoverQuery.addEventListener('change', scheduleArchiveCoverFocus);
      }
    }

    /* LothariOnline's opener: type, catch a typo, correct it, and try again. */
    const lotharioTyping = document.querySelector('[data-lo-typing]');

    if (lotharioTyping instanceof HTMLElement) {
      const finalMessage = 'Hullo, I come in peace and curiosity 👽';
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      if (reducedMotion) {
        lotharioTyping.textContent = finalMessage;
      } else {
        const wait = (milliseconds: number) =>
          new Promise<void>((resolve) => window.setTimeout(resolve, milliseconds));

        const typeText = async (text: string, pace = 68) => {
          for (const character of text) {
            lotharioTyping.textContent += character;
            await wait(pace + Math.random() * 38);
          }
        };

        const eraseText = async (count: number) => {
          for (let index = 0; index < count; index += 1) {
            lotharioTyping.textContent = (lotharioTyping.textContent ?? '').slice(0, -1);
            await wait(105);
          }
        };

        const playOpener = async () => {
          while (lotharioTyping.isConnected) {
            lotharioTyping.textContent = '';
            await wait(750);
            await typeText('Hullo, I cmoe');
            await wait(430);
            await eraseText(3);
            await typeText('ome');
            await wait(240);
            await typeText(' in peace and curiosoty');
            await wait(520);
            await eraseText(3);
            await typeText('ity');
            await wait(320);
            await typeText(' 👽', 105);
            await wait(2700);
          }
        };

        void playOpener();
      }
    }

    /* Genesis: once the final line has been reached, Adam rewrites Valentin. */
    const genesisEnd = document.querySelector('[data-genesis-end]');
    const genesisNames = Array.from(document.querySelectorAll<HTMLElement>('[data-genesis-name]'));
    const genesisToggle = document.querySelector('[data-genesis-toggle]');
    const genesisStatus = document.querySelector('[data-genesis-status]');
    const genesisPage = genesisEnd?.closest('.archived-piece-page--genesis');

    if (
      genesisEnd instanceof HTMLElement &&
      genesisPage instanceof HTMLElement &&
      genesisNames.length > 0
    ) {
      type GenesisName = 'valentin' | 'adam';
      let genesisState: GenesisName = 'valentin';
      let genesisReady = false;
      let genesisRewriteTimer = 0;
      let genesisEndTimer = 0;
      const genesisReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      const applyGenesisState = (nextState: GenesisName, announce = true) => {
        window.clearTimeout(genesisRewriteTimer);

        const commitRewrite = () => {
          const rewritten = nextState === 'adam';

          for (const name of genesisNames) {
            name.textContent = rewritten ? 'Adam' : 'Valentin';
            name.dataset.genesisCurrent = nextState;
            name.title = rewritten ? 'Restore Valentin' : 'Rewrite as Adam';
          }

          genesisState = nextState;
          genesisReady = true;
          genesisPage.classList.toggle('is-genesis-adam', rewritten);
          genesisPage.classList.add('is-genesis-ready');
          genesisPage.classList.remove('is-genesis-rewriting');

          if (genesisToggle instanceof HTMLButtonElement) {
            genesisToggle.disabled = false;
            genesisToggle.setAttribute(
              'aria-label',
              rewritten
                ? 'Restore Valentin throughout the story'
                : 'Rewrite Valentin as Adam throughout the story'
            );
          }

          if (announce && genesisStatus instanceof HTMLElement) {
            genesisStatus.textContent = rewritten
              ? 'Adam has overwritten Valentin throughout the story.'
              : 'Valentin has been restored throughout the story.';
          }
        };

        if (genesisReducedMotion) {
          commitRewrite();
          return;
        }

        genesisPage.classList.add('is-genesis-rewriting');
        genesisRewriteTimer = window.setTimeout(commitRewrite, 180);
      };

      genesisPage.addEventListener('click', (event) => {
        const target = event.target;
        if (!genesisReady || !(target instanceof Element)) return;
        if (!target.closest('[data-genesis-name], [data-genesis-toggle]')) return;

        applyGenesisState(genesisState === 'adam' ? 'valentin' : 'adam');
      });

      const genesisObserver = new IntersectionObserver((entries) => {
        const endingIsVisible = entries.some(
          (observed) => observed.isIntersecting && observed.intersectionRatio >= 1
        );

        window.clearTimeout(genesisEndTimer);
        if (!endingIsVisible) return;

        genesisEndTimer = window.setTimeout(() => {
          applyGenesisState('adam');
          genesisObserver.disconnect();
        }, 1200);
      }, { threshold: 1 });

      genesisObserver.observe(genesisEnd);
    }
  </script>
</BaseLayout>

<style>
  .account-title {
    font-size: clamp(2.4rem, 6vw, 5rem);
  }

  .account-meta {
    margin: 18px 0 0;
    color: var(--muted);
    font-size: 0.78rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .account-outbound {
    margin: 34px 0 0;
    font-size: 0.9rem;
  }

  .account-outbound a {
    border-bottom: 1px solid var(--border-strong);
    color: var(--text-soft);
    transition: border-color 240ms ease, color 240ms ease;
  }

  .account-outbound a:hover,
  .account-outbound a:focus-visible {
    border-color: var(--text);
    color: var(--text);
  }
</style>
