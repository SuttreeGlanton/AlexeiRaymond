---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CycleIcon from '../../components/CycleIcon.astro';
import PieceCard from '../../components/PieceCard.astro';
import type { Cycle } from '../../lib/data';
import { cycles, isUpcoming, parseDate, piecesForCycle, site } from '../../lib/data';
import { withBase } from '../../lib/paths';

export function getStaticPaths() {
  return cycles.map((cycle) => ({
    params: { id: cycle.id },
    props: { cycle }
  }));
}

interface Props {
  cycle: Cycle;
}

const { cycle } = Astro.props;
// Upcoming pieces first, then published pieces newest to oldest.
const cyclePieces = piecesForCycle(cycle.name)
  .slice()
  .sort((a, b) => {
    const aUpcoming = isUpcoming(a);
    const bUpcoming = isUpcoming(b);

    if (aUpcoming !== bUpcoming) return aUpcoming ? -1 : 1;

    return (parseDate(b.date)?.getTime() ?? 0) - (parseDate(a.date)?.getTime() ?? 0);
  });
const otherCycles = cycles;
---

<BaseLayout title={`${cycle.name} — ${site.author}`} description={cycle.blurb || site.bio}>
  <div class="cycle-shell" data-cycle-id={cycle.id}>
    <section class="page-shell page-hero" aria-labelledby="cycle-title">
      <a class="back-link" href={withBase('')}>&larr; All cycles</a>
      <h1 class="cycle-title" id="cycle-title"><CycleIcon id={cycle.id} />{cycle.name}</h1>
      {cycle.blurb && <p class="cycle-intro">{cycle.blurb}</p>}

      <nav class="cycle-switcher" aria-label="Cycle navigation">
        <span class="cycle-switcher-label">Cycles</span>
        <div class="cycle-switcher-links">
          {otherCycles.map((item) => (
            <a
              href={withBase(`cycles/${item.id}/`)}
              aria-current={item.id === cycle.id ? 'page' : undefined}
            >
              {item.name}
            </a>
          ))}
        </div>
      </nav>
    </section>

    <section class="page-shell" aria-label={`${cycle.name} pieces`}>
      <div class="piece-grid cycle-piece-carousel" data-mobile-focus-carousel>
        {cyclePieces.map((piece) => <PieceCard piece={piece} />)}
      </div>
    </section>
  </div>

  <script>
    /* Mobile cycle carousel focused cover color. */
    (() => {
      const media = window.matchMedia('(max-width: 640px)');
      const carousels = Array.from(document.querySelectorAll('[data-mobile-focus-carousel]'));

      if (!carousels.length) return;

      function updateCarousel(carousel) {
        const cards = Array.from(carousel.querySelectorAll('.piece-card'));

        if (!cards.length) return;

        if (!media.matches) {
          cards.forEach((card) => card.classList.remove('is-mobile-focus'));
          return;
        }

        const carouselRect = carousel.getBoundingClientRect();
        const carouselCenter = carouselRect.left + carouselRect.width / 2;

        let closestCard = cards[0];
        let closestDistance = Infinity;

        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;
          const distance = Math.abs(cardCenter - carouselCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestCard = card;
          }
        });

        cards.forEach((card) => {
          card.classList.toggle('is-mobile-focus', card === closestCard);
        });
      }

      carousels.forEach((carousel) => {
        let frame = 0;

        function scheduleUpdate() {
          cancelAnimationFrame(frame);
          frame = requestAnimationFrame(() => updateCarousel(carousel));
        }

        carousel.addEventListener('scroll', scheduleUpdate, { passive: true });
        window.addEventListener('resize', scheduleUpdate);

        if (media.addEventListener) {
          media.addEventListener('change', scheduleUpdate);
        } else if (media.addListener) {
          media.addListener(scheduleUpdate);
        }

        scheduleUpdate();
      });
    })();
  </script>

</BaseLayout>
