---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CycleHero from '../../components/CycleHero.astro';
import PieceCard from '../../components/PieceCard.astro';
import type { Cycle } from '../../lib/data';
import { cycles, isUpcoming, parseDate, piecesForCycle, site } from '../../lib/data';
import { imageAsset } from '../../lib/image-assets';
import { absoluteSiteUrl, withBase } from '../../lib/paths';

export function getStaticPaths() {
  return cycles.filter((cycle) => !cycle.disabled).map((cycle) => ({
    params: { id: cycle.id },
    props: { cycle }
  }));
}

interface Props {
  cycle: Cycle;
}

const { cycle } = Astro.props;
const cycleBanner = imageAsset(cycle.banner);
if (!cycleBanner) throw new Error(`Missing banner for cycle: ${cycle.name}`);
const cycleSourcePieces = piecesForCycle(cycle.name);
const storyOrder = cycle.storyOrder ?? [];
const hasStoryOrder = cycle.id !== 'dreams' && storyOrder.length > 0;
const storyIndex = new Map(storyOrder.map((title, index) => [title, index + 1]));
const sourceIndex = new Map(cycleSourcePieces.map((piece, index) => [piece.title, index]));

// Publication order is the initial view: upcoming work first, followed by
// published work newest to oldest. Piece order later rearranges every card.
const upcomingCyclePieces = cycleSourcePieces.filter(isUpcoming);
const publishedCyclePieces = cycleSourcePieces
  .filter((piece) => !isUpcoming(piece))
  .sort((a, b) => (parseDate(b.date)?.getTime() ?? 0) - (parseDate(a.date)?.getTime() ?? 0));
const cyclePieces = [...upcomingCyclePieces, ...publishedCyclePieces];
const priorityPiece = cyclePieces.find((piece) => Boolean(piece.cover));
const otherCycles = cycles.filter((item) => !item.disabled);
const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: site.author,
      item: absoluteSiteUrl('', Astro.site)
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: cycle.name,
      item: absoluteSiteUrl(`cycles/${cycle.id}/`, Astro.site)
    }
  ]
};
---

<BaseLayout title={`${cycle.name} — ${site.author}`} description={cycle.blurb || site.bio} structuredData={breadcrumbSchema}>
  <div
    class="cycle-shell"
    data-cycle-id={cycle.id}
    data-cycle-order-root={hasStoryOrder ? '' : undefined}
    data-order-mode={hasStoryOrder ? 'publication' : undefined}
  >
    <CycleHero cycle={cycle} image={cycleBanner} />

    <section class="page-shell cycle-navigation" aria-label="Cycle navigation">
      <nav class="cycle-switcher" aria-label="Cycle navigation">
        <span class="cycle-switcher-label">Cycles</span>
        <div class="cycle-switcher-links">
          {otherCycles.map((item) => (
            <a
              href={withBase(`cycles/${item.id}/`)}
              aria-current={item.id === cycle.id ? 'page' : undefined}
            >
              {item.name}
            </a>
          ))}
        </div>
      </nav>
    </section>

    <section class="page-shell" aria-label={`${cycle.name} pieces`}>
      {hasStoryOrder && (
        <div class="cycle-order-bar">
          <span class="cycle-order-label" id={`cycle-order-label-${cycle.id}`}>Order</span>
          <div class="cycle-order-toggle" role="group" aria-labelledby={`cycle-order-label-${cycle.id}`}>
            <button
              type="button"
              class="sort-button is-active"
              data-cycle-order="publication"
              aria-pressed="true"
              aria-controls={`cycle-grid-${cycle.id}`}
            >Publication order</button>
            <button
              type="button"
              class="sort-button"
              data-cycle-order="story"
              aria-pressed="false"
              aria-controls={`cycle-grid-${cycle.id}`}
            >Piece order</button>
          </div>
          <span class="sr-only" aria-live="polite" data-cycle-order-status></span>
        </div>
      )}
      <div
        class="piece-grid cycle-piece-carousel"
        id={`cycle-grid-${cycle.id}`}
        data-mobile-focus-carousel
        data-cycle-order-grid={hasStoryOrder ? '' : undefined}
      >
        {cyclePieces.map((piece) => (
          <PieceCard
            piece={piece}
            storyOrder={hasStoryOrder ? storyIndex.get(piece.title) : undefined}
            sourceOrder={sourceIndex.get(piece.title)}
            priority={piece === priorityPiece}
          />
        ))}
      </div>
    </section>
  </div>

  <script>
    /* Cycle cards: animated publication/narrative sort, including upcoming work. */
    (() => {
      const root = document.querySelector<HTMLElement>('[data-cycle-order-root]');
      const grid = root?.querySelector<HTMLElement>('[data-cycle-order-grid]');
      const buttons = root
        ? Array.from(root.querySelectorAll<HTMLButtonElement>('[data-cycle-order]'))
        : [];
      const status = root?.querySelector<HTMLElement>('[data-cycle-order-status]');

      if (!(root instanceof HTMLElement) || !(grid instanceof HTMLElement) || !buttons.length) return;

      type CycleOrderMode = 'story' | 'publication';
      const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const mobileLayout = window.matchMedia('(max-width: 640px)');

      const numericData = (card: HTMLElement, key: 'storyOrder' | 'sourceOrder' | 'publicationTime') =>
        Number(card.dataset[key] || 0);

      const applyOrder = (mode: CycleOrderMode) => {
        const cards = Array.from(grid.querySelectorAll<HTMLElement>(':scope > [data-piece-card]'));
        cards.forEach((card) => card.getAnimations().forEach((animation) => animation.cancel()));
        const firstPositions = new Map(cards.map((card) => [card, card.getBoundingClientRect()]));
        const previousScrollLeft = grid.scrollLeft;
        const ordered = cards.slice();

        ordered.sort((a, b) => {
          if (mode === 'story') {
            return numericData(a, 'storyOrder') - numericData(b, 'storyOrder');
          }

          const aUpcoming = a.dataset.upcoming === 'true';
          const bUpcoming = b.dataset.upcoming === 'true';
          if (aUpcoming !== bUpcoming) return aUpcoming ? -1 : 1;

          if (aUpcoming && bUpcoming) {
            return numericData(a, 'sourceOrder') - numericData(b, 'sourceOrder');
          }

          const dateDifference = numericData(b, 'publicationTime') - numericData(a, 'publicationTime');
          return dateDifference || numericData(a, 'sourceOrder') - numericData(b, 'sourceOrder');
        });

        for (const card of ordered) {
          grid.appendChild(card);
        }

        grid.scrollLeft = previousScrollLeft;
        root.dataset.orderMode = mode;

        for (const button of buttons) {
          const active = button.dataset.cycleOrder === mode;
          button.classList.toggle('is-active', active);
          button.setAttribute('aria-pressed', active ? 'true' : 'false');
        }

        if (status) {
          status.textContent = mode === 'story'
            ? 'Showing pieces in piece order.'
            : 'Showing pieces in publication order, latest first.';
        }

        if (!reducedMotion && !mobileLayout.matches) {
          for (const card of cards) {
            const first = firstPositions.get(card);
            const last = card.getBoundingClientRect();
            if (!first) continue;

            const deltaX = first.left - last.left;
            const deltaY = first.top - last.top;
            if (Math.abs(deltaX) < 1 && Math.abs(deltaY) < 1) continue;

            card.animate(
              [
                { transform: `translate(${deltaX}px, ${deltaY}px)` },
                { transform: 'translate(0, 0)' }
              ],
              { duration: 460, easing: 'cubic-bezier(0.22, 1, 0.36, 1)' }
            );
          }
        }

        grid.dispatchEvent(new Event('scroll'));
      };

      for (const button of buttons) {
        button.addEventListener('click', () => {
          const mode = button.dataset.cycleOrder;
          if (mode === 'story' || mode === 'publication') applyOrder(mode);
        });
      }
    })();

    /* Mobile cycle carousel focused cover color. */
    (() => {
      const media = window.matchMedia('(max-width: 640px)');
      const carousels = Array.from(document.querySelectorAll<HTMLElement>('[data-mobile-focus-carousel]'));

      if (!carousels.length) return;

      function updateCarousel(carousel: HTMLElement) {
        const cards = Array.from(carousel.querySelectorAll<HTMLElement>('.piece-card'));

        if (!cards.length) return;

        if (!media.matches) {
          cards.forEach((card) => card.classList.remove('is-mobile-focus'));
          return;
        }

        const carouselRect = carousel.getBoundingClientRect();
        const carouselCenter = carouselRect.left + carouselRect.width / 2;

        let closestCard = cards[0];
        let closestDistance = Infinity;

        cards.forEach((card) => {
          const rect = card.getBoundingClientRect();
          const cardCenter = rect.left + rect.width / 2;
          const distance = Math.abs(cardCenter - carouselCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestCard = card;
          }
        });

        cards.forEach((card) => {
          card.classList.toggle('is-mobile-focus', card === closestCard);
        });
      }

      carousels.forEach((carousel) => {
        let frame = 0;

        function scheduleUpdate() {
          cancelAnimationFrame(frame);
          frame = requestAnimationFrame(() => updateCarousel(carousel));
        }

        carousel.addEventListener('scroll', scheduleUpdate, { passive: true });
        window.addEventListener('resize', scheduleUpdate);

        if (media.addEventListener) {
          media.addEventListener('change', scheduleUpdate);
        } else if (media.addListener) {
          media.addListener(scheduleUpdate);
        }

        scheduleUpdate();
      });
    })();
  </script>

</BaseLayout>
