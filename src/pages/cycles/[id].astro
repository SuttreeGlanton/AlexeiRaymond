---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PieceCard from '../../components/PieceCard.astro';
import type { Cycle } from '../../lib/data';
import { cycles, isUpcoming, piecesForCycle, site } from '../../lib/data';
import { withBase } from '../../lib/paths';

export function getStaticPaths() {
  return cycles.map((cycle) => ({
    params: { id: cycle.id },
    props: { cycle }
  }));
}

interface Props {
  cycle: Cycle;
}

const { cycle } = Astro.props;
// Published pieces first, upcoming always at the bottom of the page.
const allPieces = piecesForCycle(cycle.name);
const cyclePieces = [...allPieces.filter((piece) => !isUpcoming(piece)), ...allPieces.filter(isUpcoming)];
---

<BaseLayout title={`${cycle.name} — ${site.author}`} description={cycle.blurb || site.bio}>
  <div class="cycle-shell" data-cycle-id={cycle.id}>
    <section class="page-shell page-hero" aria-labelledby="cycle-title">
      <a class="back-link" href={withBase('')}>&larr; All cycles</a>
      <h1 class="cycle-title" id="cycle-title">{cycle.name}</h1>
      {cycle.blurb && <p class="cycle-intro">{cycle.blurb}</p>}
    </section>

    <section class="page-shell" aria-label={`${cycle.name} pieces`}>
      <div class="piece-grid">
        {cyclePieces.map((piece) => <PieceCard piece={piece} />)}
      </div>
    </section>
  </div>
</BaseLayout>
