---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import aboutVisual from '../assets/page-visuals/about-portrait.jpg';
import { site, socialHref, socialLabel } from '../lib/data';
import { absoluteSiteUrl } from '../lib/paths';

const bloodHoneyUrl = 'https://www.bloodhoneylit.com/';
const bloodHoneyName = 'Blood+Honey';
const [bioBefore, bioAfter] = site.bio.split(bloodHoneyName);
const canLinkBloodHoney = typeof bioAfter === 'string';
const siteUrl = absoluteSiteUrl('', Astro.site);
const aboutUrl = absoluteSiteUrl('about/', Astro.site);
const profileSchema = {
  '@context': 'https://schema.org',
  '@type': 'ProfilePage',
  '@id': `${aboutUrl}#profile`,
  name: `About ${site.author}`,
  url: aboutUrl,
  mainEntity: {
    '@type': 'Person',
    '@id': `${siteUrl}#person`,
    name: site.author,
    url: siteUrl,
    description: site.bio,
    jobTitle: ['Writer', 'Fiction Editor'],
    worksFor: {
      '@type': 'Organization',
      name: bloodHoneyName,
      url: bloodHoneyUrl
    },
    sameAs: [
      ...site.socials.map(socialHref).filter(Boolean),
      'https://www.bloodhoneylit.com/alexei-raymond',
      'https://www.discretionarylove.com/author/alexeiraymond/'
    ]
  }
};
// Prefer a pre-encoded address so the plain email does not appear in this
// public repository. Fallback keeps the old plain-email path working.
const emailEncoded = site.emailEncoded || (site.email ? Buffer.from(site.email).toString('base64') : '');
---

<BaseLayout
  title={`About — ${site.author}`}
  description="About Alexei Raymond, his writing, editorial work, social profiles, and contact information."
  structuredData={profileSchema}
>
  <div class="page-shell page-with-visual about-with-visual">
    <section class="page-hero text-page page-copy about-copy" aria-labelledby="about-title">
      <h1 class="page-title" id="about-title">About</h1>
      <div class="prose">
        <p>
          {canLinkBloodHoney ? (
            <>
              {bioBefore}<a href={bloodHoneyUrl} target="_blank" rel="noopener noreferrer" aria-label={`${bloodHoneyName}. Opens in a new tab.`}>{bloodHoneyName}</a>{bioAfter}
            </>
          ) : (
            site.bio
          )}
        </p>
      </div>

      {site.socials.length > 0 && (
        <section class="social-block" aria-labelledby="socials-title">
          <h2 id="socials-title">Socials</h2>
          <ul class="social-list" aria-label="Social links">
            {site.socials.map((social) => {
              const href = socialHref(social);
              const label = socialLabel(social);
              return <li>{href ? <a href={href} target="_blank" rel="noopener noreferrer" aria-label={`${label}. Opens in a new tab.`}>{label}</a> : <span>{label}</span>}</li>;
            })}
          </ul>
        </section>
      )}

      {emailEncoded && (
        <section class="social-block" aria-labelledby="contact-title">
          <h2 id="contact-title">Contact</h2>
          <p class="contact-line">
            <button type="button" class="contact-reveal" data-email={emailEncoded}>Show email address</button>
          </p>
        </section>
      )}
    </section>

    <aside class="page-visual about-visual" aria-hidden="true">
      <Image
        src={aboutVisual}
        alt=""
        widths={[320, 480, 640, 914]}
        sizes="(max-width: 1080px) 1px, (max-width: 1600px) 40vw, 640px"
        format="webp"
        quality={82}
        loading="lazy"
        decoding="async"
      />
    </aside>
  </div>

  <script>
    /* Reveal the email only on interaction, decoded from base64 so it is
       never present as plain text in the page source. */
    const revealButton = document.querySelector<HTMLElement>('.contact-reveal');
    const encodedEmail = revealButton?.dataset.email;
    if (revealButton && encodedEmail) {
      revealButton.addEventListener('click', () => {
        const address = atob(encodedEmail);
        const link = document.createElement('a');
        link.href = 'mailto:' + address;
        link.textContent = address;
        link.className = 'contact-email';
        revealButton.replaceWith(link);
      }, { once: true });
    }
  </script>
</BaseLayout>
