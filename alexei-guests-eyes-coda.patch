+---
+interface Props {
+  variant: 'desktop' | 'mobile';
+}
+
+const { variant } = Astro.props;
+---
+
+<figure
+  class={`guests-eyes guests-eyes--${variant}`}
+  data-guests-eyes
+  data-variant={variant}
+  data-state="closed"
+  aria-hidden="true"
+>
+  <svg viewBox="0 0 64 12" shape-rendering="crispEdges">
+    <g class="ge-closed">
+      <path fill="#3a3834" d="M35 3h2v1h-2zM5 4h2v1h-2zM36 4h15v1h-15zM6 5h14v1h-14zM38 5h11v1h-11zM50 5h2v1h-2zM8 6h10v1h-10zM19 6h2v1h-2z" />
+      <path fill="#5f5b54" d="M38 6h4v1h-4zM44 6h4v1h-4zM8 7h4v1h-4zM14 7h4v1h-4z" />
+    </g>
+    <g class="ge-narrow">
+      <path fill="#3a3834" d="M36 2h14v1h-14zM6 3h14v1h-14zM34 3h3v1h-3zM50 3h3v1h-3zM4 4h3v1h-3zM19 4h3v1h-3zM35 4h16v1h-16zM5 5h16v1h-16z" />
+      <path fill="#5f5b54" d="M37 3h1v1h-1zM49 3h1v1h-1zM7 4h1v1h-1zM18 4h1v1h-1zM38 5h4v1h-4zM44 5h4v1h-4zM8 6h4v1h-4zM14 6h4v1h-4z" />
+      <path fill="#b7b3aa" d="M38 3h3v1h-3zM47 3h2v1h-2zM8 4h3v1h-3zM16 4h2v1h-2z" />
+      <path fill="#68645d" d="M41 3h2v1h-2zM45 3h2v1h-2zM11 4h2v1h-2zM15 4h1v1h-1z" />
+      <path fill="#1a1917" d="M43 3h2v1h-2zM13 4h2v1h-2z" />
+    </g>
+    <g class="ge-open">
+      <path fill="#3a3834" d="M36 1h14v1h-14zM6 2h14v1h-14zM34 2h2v1h-2zM51 2h2v1h-2zM4 3h2v1h-2zM20 3h2v1h-2zM33 3h1v1h-1zM53 3h1v1h-1zM3 4h1v1h-1zM22 4h1v1h-1zM33 4h1v1h-1zM52 4h1v1h-1zM4 5h1v1h-1zM21 5h1v1h-1zM34 5h2v1h-2zM50 5h2v1h-2zM5 6h2v1h-2zM19 6h2v1h-2zM37 6h12v1h-12zM7 7h12v1h-12z" />
+      <path fill="#5f5b54" d="M36 2h1v1h-1zM50 2h1v1h-1zM6 3h1v1h-1zM19 3h1v1h-1zM34 3h1v1h-1zM52 3h1v1h-1zM4 4h1v1h-1zM21 4h1v1h-1zM34 4h1v1h-1zM51 4h1v1h-1zM5 5h1v1h-1zM20 5h1v1h-1zM36 5h1v1h-1zM49 5h1v1h-1zM7 6h1v1h-1zM18 6h1v1h-1zM38 7h4v1h-4zM44 7h4v1h-4zM8 8h4v1h-4zM14 8h4v1h-4z" />
+      <path fill="#b7b3aa" d="M37 2h4v1h-4zM45 2h5v1h-5zM7 3h4v1h-4zM15 3h4v1h-4zM35 3h5v1h-5zM46 3h6v1h-6zM5 4h5v1h-5zM16 4h5v1h-5zM35 4h5v1h-5zM46 4h5v1h-5zM6 5h4v1h-4zM16 5h4v1h-4zM37 5h4v1h-4zM45 5h4v1h-4zM8 6h3v1h-3zM15 6h3v1h-3z" />
+      <path fill="#68645d" d="M41 2h4v1h-4zM11 3h4v1h-4zM40 3h6v1h-6zM10 4h6v1h-6zM40 4h6v1h-6zM10 5h6v1h-6zM41 5h4v1h-4zM11 6h4v1h-4z" />
+    </g>
+    <g class="ge-pupil">
+      <path fill="#1a1917" d="M42 3h2v1h-2zM12 4h2v1h-2zM42 4h2v1h-2zM12 5h2v1h-2z" />
+    </g>
+    <g class="ge-veins-a">
+      <path fill="#7a4038" d="M34 3h2v1h-2zM4 4h2v1h-2zM35 4h2v1h-2zM49 4h1v1h-1zM5 5h2v1h-2zM19 5h1v1h-1z" />
+    </g>
+    <g class="ge-veins-b">
+      <path fill="#7a4038" d="M50 3h1v1h-1zM20 4h1v1h-1zM49 4h2v1h-2zM19 5h2v1h-2zM36 5h1v1h-1zM6 6h1v1h-1z" />
+      <path fill="#4a322e" d="M38 7h4v1h-4zM44 7h4v1h-4zM8 8h4v1h-4zM14 8h4v1h-4z" />
+    </g>
+  </svg>
+</figure>
+
+<script>
+  const eyesInstances = Array.from(document.querySelectorAll<HTMLElement>('[data-guests-eyes]'));
+
+  if (eyesInstances.length > 0) {
+    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
+    const desktopQuery = window.matchMedia('(min-width: 861px)');
+    let stage = 0; // 0 asleep · 1 awake · 2 wearied · 3 bloodshot
+    let desktopStarted = false;
+    let mobileStarted = false;
+
+    const setStage = (next: number) => {
+      if (next > stage) stage = next;
+    };
+
+    const setState = (element: HTMLElement, state: 'closed' | 'narrow' | 'open') => {
+      element.dataset.state = state;
+    };
+
+    const applyTiredness = (element: HTMLElement, level = stage) => {
+      element.classList.toggle('is-tired-1', level >= 2);
+      element.classList.toggle('is-tired-2', level >= 3);
+    };
+
+    const wake = (element: HTMLElement, then?: () => void) => {
+      if (element.dataset.awake === 'true') {
+        then?.();
+        return;
+      }
+
+      element.dataset.awake = 'true';
+      if (reducedMotion) {
+        setState(element, 'open');
+        then?.();
+        return;
+      }
+
+      setState(element, 'narrow');
+      window.setTimeout(() => {
+        setState(element, 'open');
+        then?.();
+      }, 320);
+    };
+
+    const startDesktop = () => {
+      if (!desktopQuery.matches || desktopStarted) return;
+      desktopStarted = true;
+
+      const desktopEyes = eyesInstances.find((element) => element.dataset.variant === 'desktop');
+      const prose = document.querySelector('.archive-prose');
+      if (!(desktopEyes instanceof HTMLElement) || !(prose instanceof HTMLElement)) return;
+
+      // Preserve the current visit's state when crossing the responsive breakpoint.
+      if (stage >= 1) {
+        wake(desktopEyes);
+        applyTiredness(desktopEyes);
+      }
+
+      let ticking = false;
+      const update = () => {
+        ticking = false;
+        if (!desktopQuery.matches) return;
+
+        const rect = prose.getBoundingClientRect();
+        const progress = Math.min(1, Math.max(0, (window.innerHeight * 0.85 - rect.top) / rect.height));
+
+        // Do not infer wakefulness from article geometry at initial page load.
+        // The reader must actually move down the page.
+        if (stage < 1 && window.scrollY > 30) {
+          setStage(1);
+          wake(desktopEyes);
+        }
+
+        if (stage >= 1 && progress >= 0.86) setStage(2);
+        if (stage >= 2 && progress >= 0.94) setStage(3);
+        applyTiredness(desktopEyes);
+      };
+
+      const schedule = () => {
+        if (ticking) return;
+        ticking = true;
+        window.requestAnimationFrame(update);
+      };
+
+      window.addEventListener('scroll', schedule, { passive: true });
+      window.addEventListener('resize', schedule);
+      update();
+    };
+
+    const startMobile = () => {
+      if (desktopQuery.matches || mobileStarted) return;
+      mobileStarted = true;
+
+      const mobileEyes = eyesInstances.find((element) => element.dataset.variant === 'mobile');
+      if (!(mobileEyes instanceof HTMLElement)) return;
+
+      const revealTiredness = () => {
+        if (reducedMotion) {
+          setStage(3);
+          applyTiredness(mobileEyes, 3);
+          return;
+        }
+
+        window.setTimeout(() => {
+          setStage(2);
+          applyTiredness(mobileEyes, 2);
+        }, 1100);
+        window.setTimeout(() => {
+          setStage(3);
+          applyTiredness(mobileEyes, 3);
+        }, 2400);
+      };
+
+      const observer = new IntersectionObserver((entries) => {
+        if (!entries.some((entry) => entry.isIntersecting && entry.intersectionRatio >= 0.5)) return;
+        observer.disconnect();
+
+        window.setTimeout(() => {
+          setStage(1);
+          wake(mobileEyes, revealTiredness);
+        }, reducedMotion ? 0 : 350);
+      }, { threshold: 0.5 });
+
+      observer.observe(mobileEyes);
+    };
+
+    startDesktop();
+    startMobile();
+
+    const handleLayoutChange = () => {
+      if (desktopQuery.matches) startDesktop();
+      else startMobile();
+    };
+
+    if (typeof desktopQuery.addEventListener === 'function') {
+      desktopQuery.addEventListener('change', handleLayoutChange);
+    }
+
+    if (!reducedMotion) {
+      const eachVisibleAwake = (callback: (element: HTMLElement) => void) => {
+        for (const element of eyesInstances) {
+          if (
+            element.dataset.awake === 'true' &&
+            element.dataset.state === 'open' &&
+            element.getClientRects().length > 0
+          ) callback(element);
+        }
+      };
+
+      const blink = (hold: number) => {
+        eachVisibleAwake((element) => {
+          setState(element, 'narrow');
+          window.setTimeout(() => setState(element, 'closed'), 70);
+          window.setTimeout(() => setState(element, 'narrow'), 70 + hold);
+          window.setTimeout(() => setState(element, 'open'), 150 + hold);
+        });
+      };
+
+      const glance = () => {
+        const direction = Math.random() < 0.5 ? -2 : 2;
+        eachVisibleAwake((element) => element.style.setProperty('--ge-gaze', String(direction)));
+        window.setTimeout(() => {
+          for (const element of eyesInstances) element.style.setProperty('--ge-gaze', '0');
+        }, 1500 + Math.random() * 1800);
+      };
+
+      const idle = () => {
+        window.setTimeout(() => {
+          if (!document.hidden) {
+            const roll = Math.random();
+            if (roll < 0.4) blink(120);
+            else if (roll < 0.55) blink(950 + Math.random() * 500);
+            else if (roll < 0.8) glance();
+          }
+          idle();
+        }, 9000 + Math.random() * 17000);
+      };
+
+      idle();
+    }
+  }
+</script>
+
+<style>
+  .guests-eyes {
+    display: grid;
+    justify-items: center;
+    margin: 0;
+    text-indent: 0;
+  }
+
+  .guests-eyes--desktop {
+    margin-top: 20px;
+  }
+
+  .guests-eyes--mobile {
+    min-height: 3rem;
+    margin: clamp(4rem, 10vw, 7rem) 0 0;
+  }
+
+  .guests-eyes svg {
+    display: block;
+    width: 128px;
+    height: auto;
+    overflow: visible;
+  }
+
+  .ge-closed,
+  .ge-narrow,
+  .ge-open,
+  .ge-pupil {
+    opacity: 0;
+  }
+
+  [data-state='closed'] .ge-closed,
+  [data-state='narrow'] .ge-narrow,
+  [data-state='open'] .ge-open,
+  [data-state='open'] .ge-pupil {
+    opacity: 1;
+  }
+
+  .ge-pupil {
+    transform: translateX(calc(var(--ge-gaze, 0) * 1px));
+  }
+
+  .ge-veins-a,
+  .ge-veins-b {
+    opacity: 0;
+    transition: opacity 2.2s ease;
+  }
+
+  [data-state='open'].is-tired-1 .ge-veins-a,
+  [data-state='open'].is-tired-2 .ge-veins-b {
+    opacity: 1;
+  }
+
+  @media (max-width: 860px) {
+    .guests-eyes--desktop {
+      display: none;
+    }
+  }
+
+  @media (min-width: 861px) {
+    .guests-eyes--mobile {
+      display: none;
+    }
+  }
+
+  @media (prefers-reduced-motion: reduce) {
+    .ge-veins-a,
+    .ge-veins-b {
+      transition: none;
+    }
+
+    .ge-pupil {
+      transform: none;
+    }
+  }
+</style>
